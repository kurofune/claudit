{
  "enabledPlugins": {
    "impeccable@impeccable": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/golangci-lint.sh",
            "timeout": 60,
            "statusMessage": "Running golangci-lint…"
          }
        ]
      }
    ]
  }
}
