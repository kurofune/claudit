<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>claudit report</title>
<style>
  :root {
    --bg: #f7f8fa;
    --surface: #fff;
    --border: #e1e4e8;
    --ink: #1f2328;
    --muted: #6e7781;
    --accent: #4a90e2;
    --accent-2: #50a87a;
    --warn: #d97706;
    --hot: #d6336c;
  }
  * { box-sizing: border-box; }
  body {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
    margin: 0; padding: 0; background: var(--bg); color: var(--ink);
    font-size: 13px; line-height: 1.45;
  }
  .wrap { max-width: 1300px; margin: 0 auto; padding: 24px; }
  h1 { font-size: 1.7em; margin: 0 0 4px; }
  h2 { font-size: 1.15em; margin: 32px 0 8px; padding-bottom: 4px;
       border-bottom: 1px solid var(--border); }
  h3 { font-size: 1em; margin: 16px 0 6px; }
  .subtitle { color: var(--muted); margin-bottom: 16px; }
  .totals {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px; margin-bottom: 12px;
  }
  .stat {
    background: var(--surface); padding: 12px 14px; border: 1px solid var(--border);
    border-radius: 6px;
  }
  .stat .label { font-size: 0.8em; color: var(--muted); text-transform: uppercase;
                 letter-spacing: 0.05em; }
  .stat .value { font-size: 1.5em; font-weight: 600; margin-top: 2px;
                 font-variant-numeric: tabular-nums; }
  .controls {
    display: flex; gap: 16px; align-items: center; flex-wrap: wrap;
    background: var(--surface); padding: 10px 14px; border: 1px solid var(--border);
    border-radius: 6px; margin: 16px 0; position: sticky; top: 0; z-index: 10;
  }
  .controls label { display: flex; align-items: center; gap: 6px; }
  .controls input {
    font: inherit; padding: 4px 8px; border: 1px solid var(--border);
    border-radius: 4px; background: #fff; color: var(--ink);
  }
  .controls input[type="search"] { width: 280px; }
  .controls input[type="number"] { width: 80px; }
  .hint { color: var(--muted); font-size: 0.85em; }
  table { width: 100%; border-collapse: collapse; background: var(--surface); }
  th, td { padding: 6px 10px; border-bottom: 1px solid var(--border);
           text-align: left; vertical-align: top; }
  th { background: #eef0f2; cursor: pointer; user-select: none;
       font-weight: 600; white-space: nowrap; }
  th:hover { background: #e3e7eb; }
  th.sorted-asc::after { content: " ▲"; color: var(--accent); }
  th.sorted-desc::after { content: " ▼"; color: var(--accent); }
  td.num, th.num { text-align: right; font-variant-numeric: tabular-nums; }
  td.heat { position: relative; }
  td.heat::before {
    content: ""; position: absolute; inset: 0; right: auto;
    background: var(--hot); opacity: 0.18; pointer-events: none;
    width: var(--heat, 0%);
  }
  td.heat > * { position: relative; }
  tr.hidden { display: none; }
  details { background: var(--surface); border: 1px solid var(--border); border-radius: 6px;
            margin: 8px 0; padding: 8px 14px; }
  summary { cursor: pointer; font-weight: 600; padding: 2px 0; }
  summary > .small { color: var(--muted); font-weight: normal; margin-left: 8px; }
  .charts { display: grid; grid-template-columns: 220px 1fr; gap: 24px; align-items: start; }
  .donut { display: block; }
  .legend { font-size: 0.9em; }
  .legend-item { display: flex; align-items: center; gap: 8px; padding: 2px 0; }
  .legend-swatch { width: 12px; height: 12px; flex-shrink: 0; border-radius: 2px; }
  .hbar-list { display: flex; flex-direction: column; gap: 2px; max-width: 100%; }
  .hbar { position: relative; height: 22px; background: #eef0f2; }
  .hbar > .fill { position: absolute; left: 0; top: 0; bottom: 0;
                  background: linear-gradient(90deg, var(--accent), var(--accent-2)); }
  .hbar > .lbl, .hbar > .val { position: absolute; top: 0; line-height: 22px;
                                 font-size: 0.85em; padding: 0 6px; white-space: nowrap; }
  .hbar > .lbl { left: 0; max-width: 70%; overflow: hidden; text-overflow: ellipsis; }
  .hbar > .val { right: 0; color: #333; }
  .stacked { height: 28px; display: flex; background: #eef0f2; border-radius: 4px;
             overflow: hidden; margin: 8px 0; }
  .stacked > div { display: flex; align-items: center; justify-content: center;
                   color: white; font-size: 0.85em; font-weight: 600; }
  .pill { display: inline-block; background: #eef0f2; color: var(--muted);
          padding: 1px 8px; border-radius: 12px; font-size: 0.8em; }
  .small { font-size: 0.85em; color: var(--muted); }
  .danger { color: var(--hot); }
  .truncate { display: inline-block; max-width: 380px; overflow: hidden;
              text-overflow: ellipsis; white-space: nowrap; vertical-align: bottom; }
  details.tool-drill summary code { background: #f0f2f4; padding: 1px 6px;
                                    border-radius: 3px; }
  .row-count { color: var(--muted); font-size: 0.85em; }

  /* Hotspot cards */
  .hotspots { display: grid; grid-template-columns: 1fr; gap: 8px; }
  .hotspot {
    background: var(--surface); border: 1px solid var(--border); border-radius: 6px;
    padding: 10px 14px; transition: border-color 0.15s;
  }
  .hotspot:hover { border-color: #c8cdd2; }
  .hotspot summary { display: flex; align-items: baseline; gap: 12px;
                     list-style: none; cursor: pointer; }
  .hotspot summary::-webkit-details-marker { display: none; }
  .hotspot .rank { color: var(--muted); font-weight: 600; min-width: 1.5em; }
  .hotspot .h-title { font-weight: 600; flex: 1; overflow: hidden;
                      text-overflow: ellipsis; white-space: nowrap; }
  .hotspot .h-cost { font-weight: 600; color: var(--hot);
                     font-variant-numeric: tabular-nums; }
  .hotspot .h-pct { color: var(--muted); font-size: 0.9em;
                    font-variant-numeric: tabular-nums; }
  .hotspot[open] { border-color: var(--accent); }
  .hotspot .body { margin-top: 10px; }
  .hotspot .actions { display: flex; gap: 8px; margin: 0 0 8px; align-items: center; }
  .hotspot button.copy {
    font: inherit; padding: 4px 10px; background: var(--accent); color: white;
    border: none; border-radius: 4px; cursor: pointer;
  }
  .hotspot button.copy:hover { filter: brightness(1.1); }
  .hotspot button.copy.copied { background: var(--accent-2); }
  .hotspot pre {
    margin: 0; padding: 10px 12px; background: #f6f8fa; border: 1px solid var(--border);
    border-radius: 4px; font-size: 12px; line-height: 1.4;
    max-height: 360px; overflow: auto; white-space: pre-wrap; word-break: break-word;
  }
  .hotspot-kind {
    display: inline-block; background: #eef0f2; color: var(--muted);
    padding: 1px 6px; border-radius: 3px; font-size: 0.75em; text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Trend section + sparkline column */
  .trend-chart {
    background: var(--surface); border: 1px solid var(--border); border-radius: 6px;
    padding: 14px; margin: 8px 0 16px;
  }
  .trend-chart svg { display: block; width: 100%; height: 220px; }
  .trend-axis { stroke: var(--border); stroke-width: 1; }
  .trend-line { fill: none; stroke: var(--accent); stroke-width: 2; }
  .trend-area { fill: var(--accent); opacity: 0.12; }
  .trend-pt { fill: var(--accent); stroke: white; stroke-width: 2; }
  .trend-tick { font-size: 11px; fill: var(--muted);
                font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
  .trend-spark { vertical-align: middle; }
  .trend-spark rect { fill: var(--accent); }
  .trend-cell { white-space: nowrap; }
  .trend-summary {
    display: flex; gap: 16px; margin-top: 6px;
    color: var(--muted); font-size: 0.85em; flex-wrap: wrap;
  }
  .trend-summary strong { color: var(--ink); font-variant-numeric: tabular-nums; }
  .trend-delta-up { color: var(--hot); }
  .trend-delta-down { color: var(--accent-2); }
</style>
</head>
<body>
<div class="wrap">
  <h1>claudit report</h1>
  <div class="subtitle"><span id="date-range"></span> · <span id="row-count" class="row-count"></span></div>

  <div class="totals" id="totals"></div>

  <div id="warnings"></div>

  <h2>Top cost hotspots</h2>
  <div class="small">Each card opens to reveal a tailored prompt — click <strong>Copy prompt</strong> and paste into Claude (or any LLM) for specific advice on tools, MCPs, CLIs, and workflow patterns. The prompts forbid the trivial "use a cheaper model" answer.</div>
  <div class="hotspots" id="hotspots"></div>

  <div class="controls">
    <label>Filter rows: <input id="filter" type="search" placeholder="model, path, command, agent…"></label>
    <label>Min cost: <input id="mincost" type="number" value="0" step="0.01" min="0"></label>
    <span class="hint">Click any column header to sort. Filter and min-cost apply to every table.</span>
  </div>

  <div id="trend-section"></div>

  <h2>By model</h2>
  <div class="charts">
    <svg class="donut" width="200" height="200" viewBox="-100 -100 200 200" id="donut-model"></svg>
    <div class="legend" id="legend-model"></div>
  </div>
  <table data-table="model">
    <thead><tr>
      <th data-key="Model">Model</th>
      <th data-key="CostUSD" class="num">Cost</th>
      <th data-key="Pct" class="num">%</th>
      <th data-key="Turns" class="num">Turns</th>
      <th data-key="OutputTokens" class="num">Output tokens</th>
      <th data-key="CacheReadTokens" class="num">Cache read tokens</th>
    </tr></thead>
    <tbody></tbody>
  </table>

  <h2>By project</h2>
  <div class="hbar-list" id="bars-project"></div>
  <table data-table="project">
    <thead><tr>
      <th data-key="Project">Project</th>
      <th data-key="CostUSD" class="num">Cost</th>
      <th data-key="Pct" class="num">%</th>
      <th data-key="Sessions" class="num">Sessions</th>
      <th data-key="Turns" class="num">Turns</th>
      <th data-key="DominantModel">Dominant model</th>
    </tr></thead>
    <tbody></tbody>
  </table>

  <h2>Cache efficiency</h2>
  <div class="small">Hit ratio = <code>cache_read / (cache_read + input + cache_create_5m + cache_create_1h)</code>. Higher is better. Rows ranked by <strong>miss tokens</strong> — context paid for at full price (input) or cache-write price (cache_create) instead of cheap cache reads. Tool dimension omitted: tool-level cache hit rate is dominated by surrounding-turn context, not the tool itself.</div>
  <div id="cache-summary" class="trend-summary"></div>
  <h3 style="margin-top:18px">Worst projects by miss tokens</h3>
  <table data-table="cache-project">
    <thead><tr>
      <th data-key="Key">Project</th>
      <th data-key="HitRatio" class="num">Hit ratio</th>
      <th data-key="Miss" class="num">Miss tokens</th>
      <th data-key="CacheReadTokens" class="num">Cache read</th>
      <th data-key="Turns" class="num">Turns</th>
      <th data-key="CostUSD" class="num">Cost</th>
    </tr></thead>
    <tbody></tbody>
  </table>
  <h3 style="margin-top:18px">Worst sessions by miss tokens</h3>
  <table data-table="cache-session">
    <thead><tr>
      <th data-key="Key">Session</th>
      <th data-key="Subtitle">Project</th>
      <th data-key="HitRatio" class="num">Hit ratio</th>
      <th data-key="Miss" class="num">Miss tokens</th>
      <th data-key="CacheReadTokens" class="num">Cache read</th>
      <th data-key="Turns" class="num">Turns</th>
      <th data-key="CostUSD" class="num">Cost</th>
    </tr></thead>
    <tbody></tbody>
  </table>
  <h3 style="margin-top:18px">Worst subagent types by miss tokens</h3>
  <div class="small">Subagents start with a cold cache (each invocation is a fresh context). The miss-token volume below is the structural tax for using each subagent type.</div>
  <table data-table="cache-subagent">
    <thead><tr>
      <th data-key="Key">Subagent type</th>
      <th data-key="HitRatio" class="num">Hit ratio</th>
      <th data-key="Miss" class="num">Miss tokens</th>
      <th data-key="CacheReadTokens" class="num">Cache read</th>
      <th data-key="Turns" class="num">Turns</th>
      <th data-key="CostUSD" class="num">Cost</th>
    </tr></thead>
    <tbody></tbody>
  </table>
  <h3 style="margin-top:18px">Worst single subagent invocations by miss tokens</h3>
  <table data-table="cache-invocation">
    <thead><tr>
      <th data-key="Key">Description</th>
      <th data-key="Subtitle">Type</th>
      <th data-key="HitRatio" class="num">Hit ratio</th>
      <th data-key="Miss" class="num">Miss tokens</th>
      <th data-key="CacheReadTokens" class="num">Cache read</th>
      <th data-key="Turns" class="num">Turns</th>
      <th data-key="CostUSD" class="num">Cost</th>
    </tr></thead>
    <tbody></tbody>
  </table>

  <h2>Top expensive prompts</h2>
  <div class="small">User prompts ranked by the total cost of the assistant turn chain each one kicked off. Prompts cluster on the first 120 chars of normalized text — trivially-different repeats of the same ask appear in the same row. Hover a row's snippet for the full prompt.</div>
  <table data-table="prompt">
    <thead><tr>
      <th data-key="Sample">Snippet</th>
      <th data-key="Invocations" class="num">Invocations</th>
      <th data-key="Sessions" class="num">Sessions</th>
      <th data-key="TurnCount" class="num">Turns</th>
      <th data-key="CostUSD" class="num">Cost</th>
      <th data-key="Pct" class="num">%</th>
    </tr></thead>
    <tbody></tbody>
  </table>

  <h2>By tool</h2>
  <div class="hbar-list" id="bars-tool"></div>
  <table data-table="tool">
    <thead><tr>
      <th data-key="Name">Tool</th>
      <th data-key="Count" class="num">Calls</th>
      <th data-key="TurnCount" class="num">Turns</th>
      <th data-key="CostUSD" class="num">Cost</th>
      <th data-key="Pct" class="num">%</th>
      <th data-key="OutputTokens" class="num">Output tokens</th>
    </tr></thead>
    <tbody></tbody>
  </table>

  <h2>Drill-down by tool</h2>
  <div class="small">Each section is a (tool, argument-pattern) breakdown — e.g. Bash + <code>git status</code>. Open one to dig in.</div>
  <div id="drill-container"></div>

  <h2>By skill &amp; slash command</h2>
  <table data-table="skill">
    <thead><tr>
      <th data-key="Key">Key</th>
      <th data-key="Count" class="num">Calls</th>
      <th data-key="TurnCount" class="num">Turns</th>
      <th data-key="CostUSD" class="num">Cost</th>
      <th data-key="OutputTokens" class="num">Output tokens</th>
    </tr></thead>
    <tbody></tbody>
  </table>

  <h2>Main vs sidechain</h2>
  <div class="stacked" id="stacked-main"></div>
  <table data-table="mainside">
    <thead><tr>
      <th>Bucket</th>
      <th class="num">Cost</th>
      <th class="num">%</th>
      <th class="num">Turns</th>
      <th class="num">Cache read</th>
    </tr></thead>
    <tbody></tbody>
  </table>

  <h2>By subagent type</h2>
  <table data-table="subagent">
    <thead><tr>
      <th data-key="Type">Subagent</th>
      <th data-key="CostUSD" class="num">Cost</th>
      <th data-key="PctSide" class="num">% of sidechain</th>
      <th data-key="Turns" class="num">Turns</th>
      <th data-key="OutputTokens" class="num">Output</th>
      <th data-key="CacheReadTokens" class="num">Cache read</th>
    </tr></thead>
    <tbody></tbody>
  </table>

  <h2>Top subagent invocations</h2>
  <div class="small">Each row is one subagent run (one <code>agent-&lt;id&gt;.jsonl</code> file). Use the global filter above to narrow by subagent type, description, or project.</div>
  <table data-table="invocation">
    <thead><tr>
      <th data-key="SubagentType">Subagent</th>
      <th data-key="Description">Description</th>
      <th data-key="CostUSD" class="num">Cost</th>
      <th data-key="Turns" class="num">Turns</th>
      <th data-key="Project">Project</th>
      <th data-key="First">Started</th>
    </tr></thead>
    <tbody></tbody>
  </table>
</div>

<script id="claudit-data" type="application/json">{{.DataJSON}}</script>
<script>
(function() {
  const D = JSON.parse(document.getElementById('claudit-data').textContent);

  // ── formatting helpers ─────────────────────────────────────────────────
  const fmtMoney = v => {
    if (v == null) return '—';
    if (v >= 1000) return '$' + Math.round(v).toLocaleString();
    return '$' + v.toFixed(2);
  };
  const fmtPct = (part, total) => total > 0 ? (100 * part / total).toFixed(1) + '%' : '—';
  const fmtNum = v => v == null ? '0' : Number(v).toLocaleString();
  const fmtDate = ts => {
    if (!ts) return '—';
    try { return new Date(ts).toISOString().slice(0, 16).replace('T', ' '); }
    catch { return ts; }
  };
  const truncate = (s, n) => {
    if (!s) return '';
    if (s.length <= n) return s;
    return '…' + s.slice(s.length - n + 1);
  };
  const escHtml = s => String(s == null ? '' : s)
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

  // ── trend helpers ─────────────────────────────────────────────────────
  // Period is one of "day" | "week" | "month" | "" (disabled).
  const PERIOD = D.period || '';

  function bucketLabel(ts, period) {
    if (!ts) return '';
    const s = String(ts).slice(0, 10);          // YYYY-MM-DD
    if (period === 'month') return String(ts).slice(0, 7);
    if (period === 'week') return 'wk ' + s.slice(5);
    return s.slice(5);                          // MM-DD
  }

  // Tiny inline SVG sparkline for a table cell. Bars (rather than a
  // polyline) make sparse / single-cell series readable — a one-bucket
  // project still shows up as a single bar instead of an invisible dot.
  function trendSpark(points, w, h) {
    w = w || 90; h = h || 18;
    if (!points || points.length === 0) return '<span class="small">—</span>';
    let max = 0;
    for (const p of points) { if ((p.cost_usd || 0) > max) max = p.cost_usd; }
    const n = points.length;
    const bw = w / n;
    let bars = '';
    for (let i = 0; i < n; i++) {
      const v = points[i].cost_usd || 0;
      const bh = max > 0 ? (v / max) * (h - 1) : 0;
      const x = i * bw;
      const y = h - bh;
      bars += `<rect x="${x.toFixed(2)}" y="${y.toFixed(2)}" width="${(bw*0.85).toFixed(2)}" height="${bh.toFixed(2)}"><title>${escHtml(bucketLabel(points[i].time, PERIOD))}: ${fmtMoney(v)}</title></rect>`;
    }
    return `<svg class="trend-spark" width="${w}" height="${h}" viewBox="0 0 ${w} ${h}">${bars}</svg>`;
  }

  // Cache hit ratio per trend point. Returns 0 when no cacheable
  // traffic, mirroring the Go-side Tokens.HitRatio().
  function pointHitRatio(p) {
    const cr = p.CacheReadTokens || 0;
    const inp = p.InputTokens || 0;
    const c5 = p.CacheCreate5mTokens || 0;
    const c1 = p.CacheCreate1hTokens || 0;
    const cacheable = cr + inp + c5 + c1;
    return cacheable > 0 ? cr / cacheable : 0;
  }

  // Mini SVG line chart for hit ratio over time. Y axis fixed 0..100%
  // so the chart shape is always comparable.
  function hitRatioChart(points, period) {
    if (!points || points.length < 2) return '';
    const w = 1100, h = 90;
    const pad = { l: 60, r: 16, t: 8, b: 22 };
    const innerW = w - pad.l - pad.r;
    const innerH = h - pad.t - pad.b;
    const n = points.length;
    const xAt = i => pad.l + (i / (n - 1)) * innerW;
    const yAt = r => pad.t + innerH - r * innerH;  // r in [0,1]

    let linePts = '';
    for (let i = 0; i < n; i++) {
      linePts += `${xAt(i).toFixed(2)},${yAt(pointHitRatio(points[i])).toFixed(2)} `;
    }
    // Y gridlines at 0, 50, 100%.
    let yAxis = '';
    for (const r of [0, 0.5, 1.0]) {
      yAxis += `<line class="trend-axis" x1="${pad.l}" x2="${w - pad.r}" y1="${yAt(r).toFixed(2)}" y2="${yAt(r).toFixed(2)}" stroke-dasharray="2,3"/>`;
      yAxis += `<text class="trend-tick" x="${pad.l - 6}" y="${(yAt(r) + 4).toFixed(2)}" text-anchor="end">${(r*100).toFixed(0)}%</text>`;
    }
    let dots = '';
    for (let i = 0; i < n; i++) {
      const r = pointHitRatio(points[i]);
      dots += `<circle class="trend-pt" cx="${xAt(i).toFixed(2)}" cy="${yAt(r).toFixed(2)}" r="3"><title>${escHtml(bucketLabel(points[i].time, period))}: ${(r*100).toFixed(1)}% hit</title></circle>`;
    }
    return `<div class="small" style="margin-top:14px;font-weight:600">Cache hit ratio over ${escHtml(period)}</div>
      <svg viewBox="0 0 ${w} ${h}" preserveAspectRatio="xMidYMid meet" style="height:90px">
        ${yAxis}
        <polyline class="trend-line" points="${linePts.trim()}" style="stroke:var(--accent-2)"/>
        ${dots}
      </svg>`;
  }

  // Larger inline SVG line+area chart for the headline trend section.
  // Returns a placeholder when there's <2 points to plot.
  function trendLineChart(points, period) {
    if (!points || points.length === 0) return '<div class="small">(no trend data)</div>';
    if (points.length === 1) {
      return `<div class="small">Only one ${escHtml(period)} of data — chart hidden.</div>`;
    }
    const w = 1100, h = 220;
    const pad = { l: 60, r: 16, t: 12, b: 32 };
    const innerW = w - pad.l - pad.r;
    const innerH = h - pad.t - pad.b;
    let max = 0;
    for (const p of points) { if ((p.cost_usd || 0) > max) max = p.cost_usd; }
    if (max <= 0) max = 1;  // avoid div-by-zero; flat line at zero
    const n = points.length;
    const xAt = i => pad.l + (i / (n - 1)) * innerW;
    const yAt = v => pad.t + innerH - (v / max) * innerH;

    let linePts = '';
    for (let i = 0; i < n; i++) {
      linePts += `${xAt(i).toFixed(2)},${yAt(points[i].cost_usd || 0).toFixed(2)} `;
    }
    const areaPath =
      `M ${xAt(0).toFixed(2)} ${(pad.t + innerH).toFixed(2)} ` +
      points.map((p, i) => `L ${xAt(i).toFixed(2)} ${yAt(p.cost_usd || 0).toFixed(2)}`).join(' ') +
      ` L ${xAt(n-1).toFixed(2)} ${(pad.t + innerH).toFixed(2)} Z`;

    // Y gridlines + labels at 0, max/2, max.
    let yAxis = '';
    for (const v of [0, max / 2, max]) {
      yAxis += `<line class="trend-axis" x1="${pad.l}" x2="${w - pad.r}" y1="${yAt(v).toFixed(2)}" y2="${yAt(v).toFixed(2)}" stroke-dasharray="2,3"/>`;
      yAxis += `<text class="trend-tick" x="${pad.l - 6}" y="${(yAt(v) + 4).toFixed(2)}" text-anchor="end">${escHtml(fmtMoney(v))}</text>`;
    }

    // X tick labels: aim for ~8 evenly spaced.
    const tickCount = Math.min(n, 8);
    const tickStep = Math.max(1, Math.floor((n - 1) / (tickCount - 1)) || 1);
    let xTicks = '';
    for (let i = 0; i < n; i += tickStep) {
      xTicks += `<text class="trend-tick" x="${xAt(i).toFixed(2)}" y="${h - pad.b + 16}" text-anchor="middle">${escHtml(bucketLabel(points[i].time, period))}</text>`;
    }
    // Ensure last tick is shown.
    if ((n - 1) % tickStep !== 0) {
      xTicks += `<text class="trend-tick" x="${xAt(n-1).toFixed(2)}" y="${h - pad.b + 16}" text-anchor="middle">${escHtml(bucketLabel(points[n-1].time, period))}</text>`;
    }

    let dots = '';
    for (let i = 0; i < n; i++) {
      const v = points[i].cost_usd || 0;
      dots += `<circle class="trend-pt" cx="${xAt(i).toFixed(2)}" cy="${yAt(v).toFixed(2)}" r="3"><title>${escHtml(bucketLabel(points[i].time, period))}: ${fmtMoney(v)} · ${fmtNum(points[i].turns)} turns</title></circle>`;
    }

    return `<svg viewBox="0 0 ${w} ${h}" preserveAspectRatio="xMidYMid meet">
      ${yAxis}
      <path class="trend-area" d="${areaPath}"/>
      <polyline class="trend-line" points="${linePts.trim()}"/>
      ${dots}
      ${xTicks}
    </svg>`;
  }

  // ── palette ───────────────────────────────────────────────────────────
  const COLORS = [
    '#4a90e2', '#50a87a', '#d97706', '#9013fe', '#d6336c',
    '#0ea5e9', '#dc2626', '#16a34a', '#a855f7', '#f59e0b',
    '#64748b'
  ];

  // ── header & warnings ──────────────────────────────────────────────────
  const T = D.totals || {};
  const totalCost = T.CostUSD || 0;
  const sideCost = (D.sidechain && D.sidechain.cost) || 0;

  const dateRange = (T.First && T.Last)
    ? `${T.First.slice(0,10)} → ${T.Last.slice(0,10)}`
    : '—';
  document.getElementById('date-range').textContent = dateRange;
  document.getElementById('row-count').textContent =
    `${fmtNum(T.Sessions)} sessions · ${fmtNum(T.Turns)} assistant turns`;

  const fmtPct1 = v => (v == null || isNaN(v)) ? '—' : (100 * v).toFixed(1) + '%';
  const totalsHtml = [
    ['Total cost', fmtMoney(totalCost)],
    ['Sessions', fmtNum(T.Sessions)],
    ['Assistant turns', fmtNum(T.Turns)],
    ['Cache hit ratio', fmtPct1(D.overall_hit_ratio)],
  ].map(([l, v]) => `<div class="stat"><div class="label">${l}</div><div class="value">${v}</div></div>`).join('');
  document.getElementById('totals').innerHTML = totalsHtml;

  // ── hotspots ──────────────────────────────────────────────────────────
  (function hotspots() {
    const container = document.getElementById('hotspots');
    const list = D.hotspots || [];
    if (list.length === 0) { container.innerHTML = '<em class="small">(no hotspots — try widening --since)</em>'; return; }
    container.innerHTML = list.map((h, i) => `<details class="hotspot">
      <summary>
        <span class="rank">#${i+1}</span>
        <span class="hotspot-kind">${escHtml(h.kind.replace(/_/g, ' '))}</span>
        <span class="h-title" title="${escHtml(h.title)}">${escHtml(h.title)}</span>
        <span class="h-cost">${fmtMoney(h.cost_usd)}</span>
        <span class="h-pct">(${h.pct_of_total.toFixed(1)}%)</span>
      </summary>
      <div class="body">
        <div class="actions">
          <button class="copy" data-hotspot="${i}">📋 Copy prompt</button>
          <span class="small">Paste this into Claude or another LLM for specific advice.</span>
        </div>
        <pre>${escHtml(h.prompt)}</pre>
      </div>
    </details>`).join('');

    // Wire up copy buttons. Falls back to the older execCommand path on
    // file:// pages where navigator.clipboard is unavailable.
    container.querySelectorAll('button.copy').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        const idx = parseInt(btn.dataset.hotspot, 10);
        const text = list[idx].prompt;
        let ok = false;
        try {
          if (navigator.clipboard && navigator.clipboard.writeText) {
            await navigator.clipboard.writeText(text);
            ok = true;
          }
        } catch (err) { ok = false; }
        if (!ok) {
          // Fallback: select the <pre> and let the user Cmd-C
          const pre = btn.closest('.body').querySelector('pre');
          const range = document.createRange();
          range.selectNodeContents(pre);
          const sel = window.getSelection();
          sel.removeAllRanges(); sel.addRange(range);
          try { ok = document.execCommand('copy'); } catch { ok = false; }
        }
        const old = btn.textContent;
        btn.textContent = ok ? '✓ Copied — paste into your LLM' : '⚠ Select & copy manually';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = old; btn.classList.remove('copied'); }, 2200);
      });
    });
  })();

  if (D.unknown_models && D.unknown_models.length) {
    document.getElementById('warnings').innerHTML =
      `<div class="stat" style="border-color:var(--warn);background:#fef9e7"><strong class="danger">⚠ Unpriced models:</strong> ${D.unknown_models.map(escHtml).join(', ')} — add them to <code>~/.config/claudit/prices.yaml</code>.</div>`;
  }

  // ── trend overview section (only when --by is set) ────────────────────
  (function trendSection() {
    const host = document.getElementById('trend-section');
    if (!PERIOD || !D.trend_totals || D.trend_totals.length === 0) return;
    const points = D.trend_totals;

    // Summary stats: peak, mean, last vs prior delta.
    let peak = 0, sum = 0;
    for (const p of points) { if (p.cost_usd > peak) peak = p.cost_usd; sum += p.cost_usd; }
    const mean = sum / points.length;
    let deltaHtml = '';
    if (points.length >= 2) {
      const prev = points[points.length - 2].cost_usd || 0;
      const cur = points[points.length - 1].cost_usd || 0;
      if (prev > 0) {
        const d = 100 * (cur - prev) / prev;
        const cls = d >= 0 ? 'trend-delta-up' : 'trend-delta-down';
        const sign = d >= 0 ? '+' : '';
        deltaHtml = `<span>Latest vs prior: <strong class="${cls}">${sign}${d.toFixed(1)}%</strong></span>`;
      } else if (cur > 0) {
        deltaHtml = `<span>Latest vs prior: <strong>new</strong></span>`;
      }
    }

    // Latest-bucket hit ratio for the summary line.
    const latestHit = pointHitRatio(points[points.length - 1]);

    host.innerHTML = `
      <h2>Cost by ${escHtml(PERIOD)}</h2>
      <div class="small">Spend bucketed by ${escHtml(PERIOD)}. Per-row trend columns below use the same buckets, downsampled to ~30 cells when wider.</div>
      <div class="trend-chart">
        ${trendLineChart(points, PERIOD)}
        ${hitRatioChart(points, PERIOD)}
        <div class="trend-summary">
          <span>Buckets: <strong>${points.length}</strong></span>
          <span>Peak: <strong>${escHtml(fmtMoney(peak))}</strong></span>
          <span>Mean: <strong>${escHtml(fmtMoney(mean))}</strong></span>
          <span>Latest hit ratio: <strong>${(latestHit*100).toFixed(1)}%</strong></span>
          ${deltaHtml}
        </div>
      </div>
    `;
  })();

  // Inject Trend column header into by-model / by-project / by-tool when
  // period is on. We do this by DOM mutation rather than templating so
  // the no-period path stays byte-identical to the prior layout.
  function injectTrendColumn(tableSelector, beforeKey) {
    if (!PERIOD) return;
    const table = document.querySelector(tableSelector);
    if (!table) return;
    const headRow = table.querySelector('thead tr');
    const ths = Array.from(headRow.children);
    const idx = ths.findIndex(th => th.dataset.key === beforeKey);
    const th = document.createElement('th');
    th.dataset.key = 'Trend';
    th.textContent = 'Trend';
    if (idx >= 0) headRow.insertBefore(th, ths[idx]);
    else headRow.appendChild(th);
  }
  injectTrendColumn('[data-table="model"]', 'OutputTokens');
  injectTrendColumn('[data-table="project"]', 'DominantModel');
  injectTrendColumn('[data-table="tool"]', 'OutputTokens');

  // ── tables: build then attach data ─────────────────────────────────────
  // Each row carries its raw cost in data-cost so the global min-cost
  // filter can hide it without re-rendering.
  function attachHeat(td, value, max) {
    if (max <= 0) return;
    td.classList.add('heat');
    td.style.setProperty('--heat', Math.min(100, 100 * value / max).toFixed(1) + '%');
  }

  function buildRows(table, rows, mapper) {
    const tbody = table.querySelector('tbody');
    tbody.innerHTML = '';
    const maxCost = Math.max(0, ...rows.map(r => r.CostUSD || 0));
    rows.forEach(r => {
      const tr = document.createElement('tr');
      tr.dataset.cost = r.CostUSD || 0;
      const cells = mapper(r);
      cells.forEach(([html, isNum, heatVal]) => {
        const td = document.createElement('td');
        if (isNum) td.classList.add('num');
        td.innerHTML = html;
        if (heatVal != null) attachHeat(td, heatVal, maxCost);
        tr.appendChild(td);
      });
      tbody.appendChild(tr);
    });
    table.dataset.rows = JSON.stringify(rows);
  }

  // Helper: insert a trend-sparkline cell into a row's cell list at the
  // given column index, but only when PERIOD is on. The index must match
  // the slot where injectTrendColumn() placed the header.
  function withTrend(cells, idx, series) {
    if (!PERIOD) return cells;
    const cell = [`<span class="trend-cell">${trendSpark(series)}</span>`, false];
    return cells.slice(0, idx).concat([cell]).concat(cells.slice(idx));
  }

  // By model
  buildRows(document.querySelector('[data-table="model"]'), D.by_model || [], r => withTrend([
    [escHtml(r.Model), false],
    [fmtMoney(r.CostUSD), true, r.CostUSD],
    [fmtPct(r.CostUSD, totalCost), true],
    [fmtNum(r.Turns), true],
    [fmtNum(r.OutputTokens), true],
    [fmtNum(r.CacheReadTokens), true],
  ], 4, (D.trend_by_model || {})[r.Model]));

  // Donut + legend for by-model
  (function donut() {
    const svg = document.getElementById('donut-model');
    const leg = document.getElementById('legend-model');
    const rows = (D.by_model || []).filter(r => r.CostUSD > 0);
    const total = rows.reduce((s, r) => s + r.CostUSD, 0);
    if (total <= 0) { leg.innerHTML = '<em>(no priced data)</em>'; return; }
    let acc = 0;
    const r1 = 90, r0 = 55;
    const arcs = rows.map((row, i) => {
      const a0 = (acc / total) * Math.PI * 2 - Math.PI / 2;
      acc += row.CostUSD;
      const a1 = (acc / total) * Math.PI * 2 - Math.PI / 2;
      const large = (a1 - a0) > Math.PI ? 1 : 0;
      const p0 = [Math.cos(a0)*r1, Math.sin(a0)*r1];
      const p1 = [Math.cos(a1)*r1, Math.sin(a1)*r1];
      const q1 = [Math.cos(a1)*r0, Math.sin(a1)*r0];
      const q0 = [Math.cos(a0)*r0, Math.sin(a0)*r0];
      const color = COLORS[i % COLORS.length];
      const d = `M ${p0[0]} ${p0[1]} A ${r1} ${r1} 0 ${large} 1 ${p1[0]} ${p1[1]} L ${q1[0]} ${q1[1]} A ${r0} ${r0} 0 ${large} 0 ${q0[0]} ${q0[1]} Z`;
      return { d, color, row };
    });
    svg.innerHTML = arcs.map(a => `<path d="${a.d}" fill="${a.color}"><title>${escHtml(a.row.Model)}: ${fmtMoney(a.row.CostUSD)}</title></path>`).join('');
    leg.innerHTML = arcs.map(a => `<div class="legend-item">
      <span class="legend-swatch" style="background:${a.color}"></span>
      <span><strong>${escHtml(a.row.Model)}</strong> · ${fmtMoney(a.row.CostUSD)} (${fmtPct(a.row.CostUSD, total)})</span>
    </div>`).join('');
  })();

  // By project
  buildRows(document.querySelector('[data-table="project"]'), D.by_project || [], r => withTrend([
    [`<span class="truncate" title="${escHtml(r.Project)}">${escHtml(r.Project)}</span>`, false],
    [fmtMoney(r.CostUSD), true, r.CostUSD],
    [fmtPct(r.CostUSD, totalCost), true],
    [fmtNum(r.Sessions), true],
    [fmtNum(r.Turns), true],
    [escHtml(r.DominantModel), false],
  ], 5, (D.trend_by_project || {})[r.Project]));

  // Horizontal bar list — top 20 projects
  (function projectBars() {
    const rows = (D.by_project || []).slice(0, 20);
    const maxCost = Math.max(0, ...rows.map(r => r.CostUSD));
    document.getElementById('bars-project').innerHTML = rows.map(r => {
      const w = maxCost > 0 ? (100 * r.CostUSD / maxCost).toFixed(1) : 0;
      return `<div class="hbar">
        <div class="fill" style="width:${w}%"></div>
        <div class="lbl" title="${escHtml(r.Project)}">${escHtml(truncate(r.Project, 70))}</div>
        <div class="val">${fmtMoney(r.CostUSD)} (${fmtPct(r.CostUSD, totalCost)})</div>
      </div>`;
    }).join('');
  })();

  // Cache efficiency: project + session worst-offender tables. Sorted
  // server-side by miss tokens desc; we just render.
  (function cacheSection() {
    const proj = D.cache_by_project || [];
    const sess = D.cache_by_session || [];
    let totalMiss = 0;
    for (const r of proj) totalMiss += r.Miss || 0;
    document.getElementById('cache-summary').innerHTML = `
      <span>Overall hit ratio: <strong>${fmtPct1(D.overall_hit_ratio)}</strong></span>
      <span>Total miss tokens: <strong>${fmtNum(totalMiss)}</strong></span>
      <span>Projects with cacheable traffic: <strong>${proj.length}</strong></span>
      <span>Sessions with cacheable traffic: <strong>${sess.length}</strong></span>
    `;

    buildRows(document.querySelector('[data-table="cache-project"]'), proj, r => [
      [`<span class="truncate" title="${escHtml(r.Key)}">${escHtml(r.Key)}</span>`, false],
      [fmtPct1(r.HitRatio), true],
      [fmtNum(r.Miss), true, r.Miss],
      [fmtNum(r.CacheReadTokens), true],
      [fmtNum(r.Turns), true],
      [fmtMoney(r.CostUSD), true],
    ]);

    buildRows(document.querySelector('[data-table="cache-session"]'), sess, r => [
      [`<code>${escHtml((r.Key || '').slice(0, 8))}…</code>`, false],
      [`<span class="truncate" title="${escHtml(r.Subtitle)}">${escHtml(truncate(r.Subtitle || '', 60))}</span>`, false],
      [fmtPct1(r.HitRatio), true],
      [fmtNum(r.Miss), true, r.Miss],
      [fmtNum(r.CacheReadTokens), true],
      [fmtNum(r.Turns), true],
      [fmtMoney(r.CostUSD), true],
    ]);

    const subs = D.cache_by_subagent || [];
    buildRows(document.querySelector('[data-table="cache-subagent"]'), subs, r => [
      [escHtml(r.Key), false],
      [fmtPct1(r.HitRatio), true],
      [fmtNum(r.Miss), true, r.Miss],
      [fmtNum(r.CacheReadTokens), true],
      [fmtNum(r.Turns), true],
      [fmtMoney(r.CostUSD), true],
    ]);

    const invs = D.cache_by_invocation || [];
    buildRows(document.querySelector('[data-table="cache-invocation"]'), invs, r => [
      [`<span class="truncate" title="${escHtml(r.Key)}">${escHtml(truncate(r.Key, 80))}</span>`, false],
      [escHtml(r.Subtitle || '(unknown)'), false],
      [fmtPct1(r.HitRatio), true],
      [fmtNum(r.Miss), true, r.Miss],
      [fmtNum(r.CacheReadTokens), true],
      [fmtNum(r.Turns), true],
      [fmtMoney(r.CostUSD), true],
    ]);
  })();

  // By tool
  buildRows(document.querySelector('[data-table="tool"]'), D.by_tool || [], r => withTrend([
    [escHtml(r.Name), false],
    [fmtNum(r.Count), true],
    [fmtNum(r.TurnCount), true],
    [fmtMoney(r.CostUSD), true, r.CostUSD],
    [fmtPct(r.CostUSD, totalCost), true],
    [fmtNum(r.OutputTokens), true],
  ], 5, (D.trend_by_tool || {})[r.Name]));

  // Tool bars
  (function toolBars() {
    const rows = D.by_tool || [];
    const maxCost = Math.max(0, ...rows.map(r => r.CostUSD));
    document.getElementById('bars-tool').innerHTML = rows.map(r => {
      const w = maxCost > 0 ? (100 * r.CostUSD / maxCost).toFixed(1) : 0;
      return `<div class="hbar">
        <div class="fill" style="width:${w}%"></div>
        <div class="lbl">${escHtml(r.Name)}</div>
        <div class="val">${fmtMoney(r.CostUSD)} · ${fmtNum(r.Count)} calls</div>
      </div>`;
    }).join('');
  })();

  // Drill-down per tool
  (function drill() {
    const det = D.by_tool_detail || {};
    const tools = (D.by_tool || []).filter(t => det[t.Name] && det[t.Name].length);
    const container = document.getElementById('drill-container');
    container.innerHTML = tools.map(tool => {
      const rows = det[tool.Name];
      const max = tool.CostUSD || 1;
      const tbody = rows.slice(0, 50).map(r => `<tr data-cost="${r.CostUSD}">
        <td><code>${escHtml(r.Detail)}</code></td>
        <td class="num">${fmtNum(r.Count)}</td>
        <td class="num">${fmtNum(r.TurnCount)}</td>
        <td class="num heat" style="--heat:${Math.min(100,100*r.CostUSD/max).toFixed(1)}%">${fmtMoney(r.CostUSD)}</td>
        <td class="num">${fmtPct(r.CostUSD, tool.CostUSD)}</td>
        <td class="num">${fmtNum(r.OutputTokens)}</td>
      </tr>`).join('');
      const more = rows.length > 50 ? `<tr><td colspan="6" class="small"><em>${rows.length - 50} more rows hidden — use the JSON output (<code>--json</code>) for the full list.</em></td></tr>` : '';
      return `<details class="tool-drill" data-table="drill-${escHtml(tool.Name)}">
        <summary>${escHtml(tool.Name)} <span class="small">— ${fmtMoney(tool.CostUSD)} across ${fmtNum(tool.Count)} call(s) · ${rows.length} pattern(s)</span></summary>
        <table>
          <thead><tr>
            <th data-key="Detail">Pattern</th>
            <th data-key="Count" class="num">Calls</th>
            <th data-key="TurnCount" class="num">Turns</th>
            <th data-key="CostUSD" class="num">Cost</th>
            <th data-key="Pct" class="num">% of ${escHtml(tool.Name)}</th>
            <th data-key="OutputTokens" class="num">Output tokens</th>
          </tr></thead>
          <tbody>${tbody}${more}</tbody>
        </table>
      </details>`;
    }).join('');
  })();

  // Top expensive prompts. Sample is the full text; show the head as the
  // visible snippet, full text on hover.
  buildRows(document.querySelector('[data-table="prompt"]'), D.by_prompt || [], r => {
    const sample = r.Sample || r.Key || '';
    const head = sample.length > 80 ? sample.slice(0, 79) + '…' : sample;
    return [
      [`<span title="${escHtml(sample)}">${escHtml(head)}</span>`, false],
      [fmtNum(r.Invocations), true],
      [fmtNum(r.Sessions), true],
      [fmtNum(r.TurnCount || r.turn_count || 0), true],
      [fmtMoney(r.CostUSD), true, r.CostUSD],
      [fmtPct(r.CostUSD, totalCost), true],
    ];
  });

  // By skill
  buildRows(document.querySelector('[data-table="skill"]'), D.by_skill || [], r => [
    [`<code>${escHtml(r.Key)}</code>`, false],
    [fmtNum(r.Count), true],
    [fmtNum(r.TurnCount), true],
    [fmtMoney(r.CostUSD), true, r.CostUSD],
    [fmtNum(r.OutputTokens), true],
  ]);

  // Main vs sidechain stacked bar + table
  (function mainSide() {
    const main = D.main || {cost:0,turns:0,tokens:{}};
    const side = D.sidechain || {cost:0,turns:0,tokens:{}};
    const total = main.cost + side.cost;
    const stacked = document.getElementById('stacked-main');
    if (total > 0) {
      const mp = 100 * main.cost / total, sp = 100 - mp;
      stacked.innerHTML = `
        <div style="width:${mp}%;background:var(--accent)" title="main: ${fmtMoney(main.cost)}">main · ${mp.toFixed(1)}%</div>
        <div style="width:${sp}%;background:var(--accent-2)" title="sidechain: ${fmtMoney(side.cost)}">sidechain · ${sp.toFixed(1)}%</div>`;
    }
    const tbody = document.querySelector('[data-table="mainside"] tbody');
    const buckets = [
      ['main', main.cost, main.turns, (main.tokens||{}).CacheReadTokens],
      ['sidechain', side.cost, side.turns, (side.tokens||{}).CacheReadTokens],
    ];
    tbody.innerHTML = buckets.map(([n, c, t, cr]) =>
      `<tr data-cost="${c}"><td>${n}</td><td class="num">${fmtMoney(c)}</td><td class="num">${fmtPct(c, total)}</td><td class="num">${fmtNum(t)}</td><td class="num">${fmtNum(cr)}</td></tr>`
    ).join('');
  })();

  // By subagent
  buildRows(document.querySelector('[data-table="subagent"]'), D.by_subagent || [], r => [
    [escHtml(r.Type), false],
    [fmtMoney(r.CostUSD), true, r.CostUSD],
    [fmtPct(r.CostUSD, sideCost), true],
    [fmtNum(r.Turns), true],
    [fmtNum(r.OutputTokens), true],
    [fmtNum(r.CacheReadTokens), true],
  ]);

  // Agent invocations
  buildRows(document.querySelector('[data-table="invocation"]'), D.agent_invocations || [], r => [
    [escHtml(r.SubagentType || '(unknown)'), false],
    [`<span title="${escHtml(r.Description)}">${escHtml(truncate(r.Description, 80))}</span>`, false],
    [fmtMoney(r.CostUSD), true, r.CostUSD],
    [fmtNum(r.Turns), true],
    [`<span class="truncate" title="${escHtml(r.Project)}">${escHtml(truncate(r.Project, 50))}</span>`, false],
    [fmtDate(r.First), false],
  ]);

  // ── sorting ───────────────────────────────────────────────────────────
  document.querySelectorAll('table thead th[data-key]').forEach(th => {
    th.addEventListener('click', () => {
      const table = th.closest('table');
      const tbody = table.querySelector('tbody');
      const idx = Array.from(th.parentNode.children).indexOf(th);
      const asc = !th.classList.contains('sorted-asc');
      table.querySelectorAll('thead th').forEach(h => h.classList.remove('sorted-asc', 'sorted-desc'));
      th.classList.add(asc ? 'sorted-asc' : 'sorted-desc');
      const rows = Array.from(tbody.querySelectorAll('tr'));
      rows.sort((a, b) => {
        const av = a.children[idx]?.textContent.trim() || '';
        const bv = b.children[idx]?.textContent.trim() || '';
        const an = parseFloat(av.replace(/[^0-9.\-]/g, ''));
        const bn = parseFloat(bv.replace(/[^0-9.\-]/g, ''));
        const numeric = !isNaN(an) && !isNaN(bn) && (av.match(/[0-9]/) || bv.match(/[0-9]/));
        const cmp = numeric ? (an - bn) : av.localeCompare(bv);
        return asc ? cmp : -cmp;
      });
      rows.forEach(r => tbody.appendChild(r));
    });
  });

  // ── global filter + min cost ──────────────────────────────────────────
  function applyFilters() {
    const q = document.getElementById('filter').value.trim().toLowerCase();
    const minCost = parseFloat(document.getElementById('mincost').value || '0');
    document.querySelectorAll('table tbody tr, details tbody tr').forEach(tr => {
      const cost = parseFloat(tr.dataset.cost || '0');
      const text = tr.textContent.toLowerCase();
      const matches = (!q || text.includes(q)) && (cost >= minCost);
      tr.classList.toggle('hidden', !matches);
    });
  }
  document.getElementById('filter').addEventListener('input', applyFilters);
  document.getElementById('mincost').addEventListener('input', applyFilters);
})();
</script>
</body>
</html>
