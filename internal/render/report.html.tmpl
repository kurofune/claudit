            <th data-key="Description" title="The description argument passed when this subagent was invoked.">Description</th>
            <th data-key="CostUSD" class="num" title="Dollar cost of this single invocation. Outliers here often signal a poorly-scoped delegation.">Cost</th>
            <th data-key="Turns" class="num" title="Assistant turns in this invocation.">Turns</th>
            <th data-key="Project" title="Working directory the parent session was running in.">Project</th>
            <th data-key="First" title="Timestamp this subagent invocation started.">Started</th>
          </tr></thead>
          <tbody></tbody>
        </table>
      </div>
    </section>

  </main>
</div>

<script id="claudit-data" type="application/json">{{.DataJSON}}</script>
<script>
(function() {
  const D = JSON.parse(document.getElementById('claudit-data').textContent);

  // ── formatting helpers ─────────────────────────────────────────────────
  const fmtMoney = v => {
    if (v == null) return '—';
    if (v >= 1000) return '$' + Math.round(v).toLocaleString();
    return '$' + v.toFixed(2);
  };
  const fmtPct = (part, total) => total > 0 ? (100 * part / total).toFixed(1) + '%' : '—';
  const fmtNum = v => v == null ? '0' : Number(v).toLocaleString();
  const fmtDate = ts => {
    if (!ts) return '—';
    try { return new Date(ts).toISOString().slice(0, 16).replace('T', ' '); }
    catch { return ts; }
  };
  const truncate = (s, n) => {
    if (!s) return '';
    if (s.length <= n) return s;
    return '…' + s.slice(s.length - n + 1);
  };
  const escHtml = s => String(s == null ? '' : s)
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

  // ── view + subtab + anchor routing ────────────────────────────────────
  // Hash forms supported:
  //   #view                       (e.g. #cost)
  //   #view/subtab                (e.g. #cost/project)
  //   #target                     (bare anchor: #hotspot-3, #session-abc)
  //   #view/target                (combined: #overview/hotspot-3)
  // Targets are scroll-and-open: the matching id'd element gets scrolled
  // into view and, if it's a <details>, opened. Lets users copy a URL
  // that deep-links to a specific hotspot or session card.
  const VIEWS = ['overview', 'cost', 'sessions', 'cache', 'tools', 'subagents'];
  const TARGET_PREFIXES = ['hotspot-', 'session-'];
  function isTargetId(s) {
    return !!s && TARGET_PREFIXES.some(p => s.startsWith(p));
  }
  function parseHash() {
    const h = (location.hash || '#overview').slice(1);
    const parts = h.split('/');
    let view, secondary;
    if (VIEWS.includes(parts[0])) {
      view = parts[0];
      secondary = parts[1] || null;
    } else if (isTargetId(parts[0])) {
      // Bare anchor — pick the view that owns this target type.
      view = parts[0].startsWith('session-') ? 'sessions' : 'overview';
      secondary = parts[0];
    } else {
      view = 'overview';
      secondary = null;
    }
    const target = isTargetId(secondary) ? secondary : null;
    return {
      view,
      subtab: target ? null : secondary,
      target,
    };
  }
  function activate({ view, subtab, target }) {
    document.querySelectorAll('.view').forEach(v => {
      v.classList.toggle('is-active', v.dataset.view === view);
    });
    document.querySelectorAll('.nav-item').forEach(a => {
      a.classList.toggle('is-active', a.dataset.view === view);
    });
    // If the active view has subtabs, default to the first when none specified.
    const activeView = document.querySelector(`.view[data-view="${view}"]`);
    if (activeView) {
      const subtabs = activeView.querySelectorAll('.subtab');
      if (subtabs.length) {
        const wanted = subtab && activeView.querySelector(`.subtab[data-subtab="${subtab}"]`)
          ? subtab
          : subtabs[0].dataset.subtab;
        subtabs.forEach(t =>
          t.classList.toggle('is-active', t.dataset.subtab === wanted));
        activeView.querySelectorAll('.subview').forEach(s =>
          s.classList.toggle('is-active', s.dataset.subview === wanted));
      }
    }
    if (target) {
      // Defer scroll one frame so the view's display:block has taken
      // effect — otherwise the element has no layout box yet and
      // scrollIntoView lands on the wrong position.
      requestAnimationFrame(() => {
        const el = document.getElementById(target);
        if (!el) return;
        if (el.tagName === 'DETAILS') el.open = true;
        el.scrollIntoView({behavior: 'smooth', block: 'start'});
      });
    } else if (window.scrollY > 0) {
      window.scrollTo({top: 0, behavior: 'instant'});
    }
  }
  activate(parseHash());
  window.addEventListener('hashchange', () => activate(parseHash()));

  // Clicking the `#` next to a hotspot or session card copies the full
  // shareable URL to the clipboard. We do NOT preventDefault — the browser's
  // default hash-link behavior is what fires hashchange and opens the card.
  // Event-delegated because anchor links are rendered after this script runs.
  document.addEventListener('click', async (e) => {
    const a = e.target.closest('a.anchor-link');
    if (!a) return;
    const url = window.location.href.split('#')[0] + a.getAttribute('href');
    let ok = false;
    try {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        await navigator.clipboard.writeText(url);
        ok = true;
      }
    } catch { ok = false; }
    if (!ok) {
      // file:// fallback — navigator.clipboard is often blocked there.
      const tmp = document.createElement('textarea');
      tmp.value = url;
      tmp.setAttribute('readonly', '');
      tmp.style.position = 'absolute';
      tmp.style.left = '-9999px';
      document.body.appendChild(tmp);
      tmp.select();
      try { ok = document.execCommand('copy'); } catch { ok = false; }
      document.body.removeChild(tmp);
    }
    const old = a.textContent;
    a.textContent = ok ? '✓' : '!';
    setTimeout(() => { a.textContent = old; }, 1200);
  });

  // ── cross-link to session drill-down ──────────────────────────────────
  // Hotspot cards (kind='prompt') and the by-prompt table both want to
  // route the user from "here's an expensive prompt" to "and here's the
  // session it ran in." Pre-build a key → location map from the timeline
  // payload so callers can check availability in O(1) and avoid offering
  // a dead link.
  const promptKeyAvailable = (function buildPromptKeySet() {
    const set = new Set();
    for (const s of (D.session_timelines || [])) {
      for (const p of (s.Prompts || [])) {
        if (p.Key) set.add(p.Key);
      }
    }
    return set;
  })();

  // jumpToPrompt routes to the Sessions view, opens the matching session
  // card + prompt block, and scrolls the prompt into view. Returns true on
  // success, false when key isn't in the timeline (e.g. session below the
  // --sessions=N cap, or prompt was orphaned).
  function jumpToPrompt(key) {
    if (!key || !promptKeyAvailable.has(key)) return false;
    // Sessions view must be active before we can find the DOM nodes —
    // earlier views may still have the section display:none'd.
    if (location.hash !== '#sessions') {
      location.hash = '#sessions';
    } else {
      activate(parseHash()); // idempotent; ensures Sessions is visible
    }
    // Defer the open+scroll one tick so the activate() above paints.
    requestAnimationFrame(() => {
      const block = document.querySelector(
        `.prompt-block[data-prompt-key="${CSS.escape(key)}"]`);
      if (!block) return;
      // Walk up: prompt-block → session-body → session-card. Open both.
      const card = block.closest('.session-card');
      if (card) card.open = true;
      block.open = true;
      block.scrollIntoView({behavior: 'smooth', block: 'start'});
    });
    return true;
  }

  // ── trend helpers ─────────────────────────────────────────────────────
  // Period is one of "day" | "week" | "month" | "" (disabled).
  const PERIOD = D.period || '';

  function bucketLabel(ts, period) {
    if (!ts) return '';
    const s = String(ts).slice(0, 10);          // YYYY-MM-DD
    if (period === 'month') return String(ts).slice(0, 7);
    if (period === 'week') return 'wk ' + s.slice(5);
    return s.slice(5);                          // MM-DD
  }

  // Tiny inline SVG sparkline for a table cell. Bars (rather than a
  // polyline) make sparse / single-cell series readable — a one-bucket
  // project still shows up as a single bar instead of an invisible dot.
  function trendSpark(points, w, h) {
    w = w || 90; h = h || 18;
    if (!points || points.length === 0) return '<span class="small">—</span>';
    let max = 0;
    for (const p of points) { if ((p.cost_usd || 0) > max) max = p.cost_usd; }
    const n = points.length;
    const bw = w / n;
    let bars = '';
    for (let i = 0; i < n; i++) {
      const v = points[i].cost_usd || 0;
      const bh = max > 0 ? (v / max) * (h - 1) : 0;
      const x = i * bw;
      const y = h - bh;
      const label = `${escHtml(bucketLabel(points[i].time, PERIOD))}: ${fmtMoney(v)}`;
      bars += `<rect x="${x.toFixed(2)}" y="${y.toFixed(2)}" width="${(bw*0.85).toFixed(2)}" height="${bh.toFixed(2)}" data-tooltip="${label}"></rect>`;
    }
    return `<svg class="trend-spark" width="${w}" height="${h}" viewBox="0 0 ${w} ${h}">${bars}</svg>`;
  }

  // anomalyIndex builds Map<bucketTimeString, Anomaly> from D.anomalies,
  // narrowed to a single kind so the cost chart and hit-ratio chart can
  // pull their own. Anomaly.time is the raw JSON timestamp string —
  // matching p.time straight from the trend payload works because they
  // come from the same RFC 3339 serialization.
  function anomalyIndex(anomalies, kind) {
    const out = new Map();
    if (!anomalies) return out;
    for (const a of anomalies) {
      if (a.kind === kind) out.set(a.time, a);
    }
    return out;
  }

  // Cache hit ratio per trend point. Returns 0 when no cacheable
  // traffic, mirroring the Go-side Tokens.HitRatio().
  function pointHitRatio(p) {
    const cr = p.CacheReadTokens || 0;
    const inp = p.InputTokens || 0;
    const c5 = p.CacheCreate5mTokens || 0;
    const c1 = p.CacheCreate1hTokens || 0;
    const cacheable = cr + inp + c5 + c1;
    return cacheable > 0 ? cr / cacheable : 0;
  }

  // Catmull-Rom → cubic-bezier path. Tension 0.5 (the standard) gives
  // natural-looking curves without overshoot on monotone-ish data. For
  // sharp peaks the smoothing is gentle enough that no clipping occurs.
  function smoothPath(pts) {
    if (!pts || pts.length === 0) return '';
    if (pts.length === 1) return `M ${pts[0][0].toFixed(2)} ${pts[0][1].toFixed(2)}`;
    let d = `M ${pts[0][0].toFixed(2)} ${pts[0][1].toFixed(2)}`;
    for (let i = 0; i < pts.length - 1; i++) {
      const p0 = pts[Math.max(0, i - 1)];
      const p1 = pts[i];
      const p2 = pts[i + 1];
      const p3 = pts[Math.min(pts.length - 1, i + 2)];
      const c1x = p1[0] + (p2[0] - p0[0]) / 6;
      const c1y = p1[1] + (p2[1] - p0[1]) / 6;
      const c2x = p2[0] - (p3[0] - p1[0]) / 6;
      const c2y = p2[1] - (p3[1] - p1[1]) / 6;
      d += ` C ${c1x.toFixed(2)} ${c1y.toFixed(2)}, ${c2x.toFixed(2)} ${c2y.toFixed(2)}, ${p2[0].toFixed(2)} ${p2[1].toFixed(2)}`;
    }
    return d;
  }

  // HTML-attribute-safe JSON encoder for embedding chart points in
  // data-chart-points. Escapes the five characters that matter inside a
  // single-quoted attribute (& ' " < >). Browsers round-trip these via
  // dataset.* automatically, so JSON.parse on the other end works.
  function encodeChartData(arr) {
    return JSON.stringify(arr).replace(/[&'"<>]/g, c => `&#${c.charCodeAt(0)};`);
  }

  // Read the panel's interior width once at chart-render time so the
  // viewBox can be sized to match the actual rendered SVG. With matching
  // viewBox/CSS dimensions, preserveAspectRatio="meet" introduces no
  // padding — the chart fills the full container end-to-end. Falls back
  // to 1100 if the panel isn't measurable yet (initial paint edge case).
  function chartViewboxWidth() {
    const p = document.querySelector('.panel');
    if (!p) return 1100;
    const r = p.getBoundingClientRect();
    const cs = window.getComputedStyle(p);
    const inner = r.width - parseFloat(cs.paddingLeft || 0) - parseFloat(cs.paddingRight || 0);
    // Subtract .trend-chart's own padding (s-3 each side ≈ 12px) so the
    // chart bg and the axis labels don't overlap the rounded corners.
    return Math.max(800, Math.round(inner - 24));
  }

  // Mini SVG line chart for hit ratio over time. Y axis fixed 0..100%
  // so the chart shape is always comparable across reports.
  function hitRatioChart(points, period, anomalies) {
    if (!points || points.length < 2) return '';
    const w = chartViewboxWidth(), h = 110;
    const pad = { l: 60, r: 16, t: 8, b: 22 };
    const innerW = w - pad.l - pad.r;
    const innerH = h - pad.t - pad.b;
    const n = points.length;
    const xAt = i => pad.l + (i / (n - 1)) * innerW;
    const yAt = r => pad.t + innerH - r * innerH;  // r in [0,1]
    const anomIdx = anomalyIndex(anomalies, 'hitratio_drop');

    const coords = points.map((p, i) => [xAt(i), yAt(pointHitRatio(p))]);
    const linePath = smoothPath(coords);
    const areaPath = linePath +
      ` L ${xAt(n-1).toFixed(2)} ${(pad.t + innerH).toFixed(2)}` +
      ` L ${xAt(0).toFixed(2)} ${(pad.t + innerH).toFixed(2)} Z`;

    // Y gridlines at 0, 50, 100%.
    let yAxis = '';
    for (const r of [0, 0.5, 1.0]) {
      yAxis += `<line class="trend-axis" x1="${pad.l}" x2="${w - pad.r}" y1="${yAt(r).toFixed(2)}" y2="${yAt(r).toFixed(2)}" stroke-dasharray="2,3"/>`;
      yAxis += `<text class="trend-tick" x="${pad.l - 6}" y="${(yAt(r) + 4).toFixed(2)}" text-anchor="end">${(r*100).toFixed(0)}%</text>`;
    }
    let dots = '', markers = '';
    for (let i = 0; i < n; i++) {
      const r = pointHitRatio(points[i]);
      const a = anomIdx.get(points[i].time);
      const cls = a ? 'trend-pt trend-pt-anomaly' : 'trend-pt';
      const rad = a ? 5 : 3;
      dots += `<circle class="${cls}" cx="${xAt(i).toFixed(2)}" cy="${yAt(r).toFixed(2)}" r="${rad}" data-i="${i}"/>`;
      if (a) {
        // Drop marker sits *below* the point so it doesn't crash into the
        // chart's narrow top padding.
        const ppGap = (a.ratio * 100).toFixed(0);
        markers += `<text class="trend-anomaly-marker" x="${xAt(i).toFixed(2)}" y="${(yAt(r) + 16).toFixed(2)}" text-anchor="middle">▼ −${ppGap}pp</text>`;
      }
    }

    const data = points.map(p => ({
      label: bucketLabel(p.time, period),
      ratio: pointHitRatio(p),
      anomaly: anomIdx.get(p.time) || null,
    }));

    return `<div class="trend-subtitle">Cache hit ratio over ${escHtml(period)}</div>
      <div class="chart-host" data-chart-type="hitratio"
           data-chart-points='${encodeChartData(data)}'
           data-pad-l="${pad.l}" data-pad-r="${pad.r}"
           data-pad-t="${pad.t}" data-pad-b="${pad.b}"
           data-vb-w="${w}" data-vb-h="${h}">
        <svg viewBox="0 0 ${w} ${h}" preserveAspectRatio="xMidYMid meet" class="trend-hitratio">
          <defs>
            <linearGradient id="grad-hit" x1="0" x2="0" y1="0" y2="1">
              <stop class="grad-stop-hit-top" offset="0%"/>
              <stop class="grad-stop-hit-bot" offset="100%"/>
            </linearGradient>
          </defs>
          ${yAxis}
          <path class="trend-area" d="${areaPath}" fill="url(#grad-hit)"/>
          <path class="trend-line trend-line-2" d="${linePath}"/>
          ${dots}
          ${markers}
          <g class="crosshair" style="opacity:0">
            <line class="crosshair-line" x1="0" x2="0" y1="${pad.t}" y2="${(pad.t + innerH).toFixed(2)}"/>
            <circle class="crosshair-dot" cx="0" cy="0" r="5"/>
          </g>
        </svg>
        <div class="chart-tooltip" role="tooltip" style="opacity:0; left:0; top:0;"></div>
      </div>`;
  }

  // Headline trend chart — line + gradient area, hover crosshair, smooth
  // bezier interpolation. Returns a placeholder when there's <2 points.
  function trendLineChart(points, period, anomalies) {
    if (!points || points.length === 0) return '<div class="small">(no trend data)</div>';
    if (points.length === 1) {
      return `<div class="small">Only one ${escHtml(period)} of data — chart hidden.</div>`;
    }
    const w = chartViewboxWidth(), h = 320;
    const pad = { l: 60, r: 16, t: 12, b: 32 };
    const innerW = w - pad.l - pad.r;
    const innerH = h - pad.t - pad.b;
    let max = 0;
    for (const p of points) { if ((p.cost_usd || 0) > max) max = p.cost_usd; }
    if (max <= 0) max = 1;
    const n = points.length;
    const xAt = i => pad.l + (i / (n - 1)) * innerW;
    const yAt = v => pad.t + innerH - (v / max) * innerH;

    const coords = points.map((p, i) => [xAt(i), yAt(p.cost_usd || 0)]);
    const linePath = smoothPath(coords);
    const areaPath = linePath +
      ` L ${xAt(n-1).toFixed(2)} ${(pad.t + innerH).toFixed(2)}` +
      ` L ${xAt(0).toFixed(2)} ${(pad.t + innerH).toFixed(2)} Z`;

    // Y gridlines at 0, max/2, max.
    let yAxis = '';
    for (const v of [0, max / 2, max]) {
      yAxis += `<line class="trend-axis" x1="${pad.l}" x2="${w - pad.r}" y1="${yAt(v).toFixed(2)}" y2="${yAt(v).toFixed(2)}" stroke-dasharray="2,3"/>`;
      yAxis += `<text class="trend-tick" x="${pad.l - 6}" y="${(yAt(v) + 4).toFixed(2)}" text-anchor="end">${escHtml(fmtMoney(v))}</text>`;
    }

    // X tick labels: pick up to 8 evenly-spaced indices from 0 to
    // n-1 inclusive. Set dedupes when rounding collides (small n).
    // Old approach used a fixed step and then force-appended n-1 if
    // it didn't fall on a multiple, which overlapped the previous
    // tick at the right edge for many corpus sizes.
    const tickCount = Math.min(n, 8);
    const tickIdx = [];
    {
      const seen = new Set();
      for (let k = 0; k < tickCount; k++) {
        const i = tickCount === 1 ? 0 : Math.round(k * (n - 1) / (tickCount - 1));
        if (!seen.has(i)) { seen.add(i); tickIdx.push(i); }
      }
    }
    let xTicks = '';
    for (const i of tickIdx) {
      xTicks += `<text class="trend-tick" x="${xAt(i).toFixed(2)}" y="${h - pad.b + 16}" text-anchor="middle">${escHtml(bucketLabel(points[i].time, period))}</text>`;
    }

    const anomIdx = anomalyIndex(anomalies, 'cost_spike');
    let dots = '', markers = '';
    for (let i = 0; i < n; i++) {
      const v = points[i].cost_usd || 0;
      const a = anomIdx.get(points[i].time);
      const cls = a ? 'trend-pt trend-pt-anomaly' : 'trend-pt';
      const rad = a ? 5 : 3;
      dots += `<circle class="${cls}" cx="${xAt(i).toFixed(2)}" cy="${yAt(v).toFixed(2)}" r="${rad}" data-i="${i}"/>`;
      if (a) {
        // Spike marker sits 10px above the dot. The tallest dot for a
        // spike is by definition near the top of the chart, but with
        // pad.t=12 there's still room; for the literal max-value dot we
        // float just below the dot instead.
        const above = yAt(v) - 10;
        const y = above < pad.t + 4 ? yAt(v) + 16 : above;
        markers += `<text class="trend-anomaly-marker" x="${xAt(i).toFixed(2)}" y="${y.toFixed(2)}" text-anchor="middle">▲ ${a.ratio.toFixed(1)}×</text>`;
      }
    }

    const data = points.map(p => ({
      label: bucketLabel(p.time, period),
      cost: p.cost_usd || 0,
      turns: p.turns || 0,
      anomaly: anomIdx.get(p.time) || null,
    }));

    return `
      <div class="chart-host" data-chart-type="cost"
           data-chart-points='${encodeChartData(data)}'
           data-pad-l="${pad.l}" data-pad-r="${pad.r}"
           data-pad-t="${pad.t}" data-pad-b="${pad.b}"
           data-vb-w="${w}" data-vb-h="${h}">
        <svg viewBox="0 0 ${w} ${h}" preserveAspectRatio="xMidYMid meet">
          <defs>
            <linearGradient id="grad-cost" x1="0" x2="0" y1="0" y2="1">
              <stop class="grad-stop-cost-top" offset="0%"/>
              <stop class="grad-stop-cost-mid" offset="60%"/>
              <stop class="grad-stop-cost-bot" offset="100%"/>
            </linearGradient>
          </defs>
          ${yAxis}
          <path class="trend-area" d="${areaPath}" fill="url(#grad-cost)"/>
          <path class="trend-line" d="${linePath}"/>
          ${dots}
          ${markers}
          ${xTicks}
          <g class="crosshair" style="opacity:0">
            <line class="crosshair-line" x1="0" x2="0" y1="${pad.t}" y2="${(pad.t + innerH).toFixed(2)}"/>
            <circle class="crosshair-dot" cx="0" cy="0" r="5"/>
          </g>
        </svg>
        <div class="chart-tooltip" role="tooltip" style="opacity:0; left:0; top:0;"></div>
      </div>`;
  }

  // ── header & warnings ──────────────────────────────────────────────────
  const T = D.totals || {};
  const totalCost = T.CostUSD || 0;
  const sideCost = (D.sidechain && D.sidechain.cost) || 0;

  const dateRange = (T.First && T.Last)
    ? `${T.First.slice(0,10)} → ${T.Last.slice(0,10)}`
    : '—';
  document.getElementById('date-range').textContent = dateRange;

  const fmtPct1 = v => (v == null || isNaN(v)) ? '—' : (100 * v).toFixed(1) + '%';

  // Semantic pill for hit-ratio values. Tier thresholds match the rules-
  // of-thumb in the cache guide — keep them in sync if either changes.
  // Pass extraClass="tier-sm" for the compact totals/nav-metric variant.
  function hitRatioPill(v, extraClass) {
    if (v == null || isNaN(v)) return '—';
    const tier = v >= 0.70 ? 'good' : v >= 0.40 ? 'ok' : 'bad';
    const cls = `tier tier-${tier}` + (extraClass ? ' ' + extraClass : '');
    return `<span class="${cls}">${fmtPct1(v)}</span>`;
  }
  // Helper to render a Lucide-style icon by sprite ID. Used for the
  // small label glyphs on totals tiles.
  const labelIcon = id => `<svg class="icon" aria-hidden="true"><use href="#icon-${id}"/></svg>`;

  // Period-over-period delta block. Compares the most recent trend
  // bucket to the one before it (e.g. this week vs last week when the
  // report ran with --by week). Returns '' when there's no comparison
  // available — single bucket, no --by, or zero prior value.
  //
  //   semantics: 'bad'  → upward direction is bad  (e.g. cost)
  //              'good' → upward direction is good (e.g. hit ratio)
  //              'neutral' → directional, but not value-laden (e.g. turns)
  //   asPP:     when true, value is interpreted as percentage POINTS
  //             instead of relative %. Used for ratios like hit ratio
  //             where "50% → 55%" reads more clearly as "+5pp" than "+10%".
  function deltaBlock(latest, prior, semantics, asPP) {
    if (latest == null || prior == null || !isFinite(latest) || !isFinite(prior)) return '';
    if (!asPP && (prior === 0 || !isFinite(latest / prior))) return '';
    const v = asPP ? (latest - prior) * 100 : (latest - prior) / prior * 100;
    if (!isFinite(v)) return '';
    const period = PERIOD ? `vs prior ${escHtml(PERIOD)}` : 'vs prior';
    const tail = `<span class="delta-tail">${period}</span>`;
    const eps = asPP ? 0.5 : 0.1;
    if (Math.abs(v) < eps) {
      return `<div class="delta delta-flat">flat <span class="delta-tail">${period}</span></div>`;
    }
    const isUp = v > 0;
    let cls = 'delta-neutral';
    if (semantics === 'bad')  cls = isUp ? 'delta-bad'  : 'delta-good';
    if (semantics === 'good') cls = isUp ? 'delta-good' : 'delta-bad';
    const iconId = isUp ? 'chevron-up' : 'chevron-down';
    const arrow = `<svg class="icon" aria-hidden="true"><use href="#icon-${iconId}"/></svg>`;
    const unit = asPP ? 'pp' : '%';
    return `<div class="delta ${cls}">${arrow}${Math.abs(v).toFixed(1)}${unit} ${tail}</div>`;
  }

  // Compute the deltas if we have at least two trend buckets.
  const _haveTrend = PERIOD && D.trend_totals && D.trend_totals.length >= 2;
  const _latest = _haveTrend ? D.trend_totals[D.trend_totals.length - 1] : null;
  const _prior  = _haveTrend ? D.trend_totals[D.trend_totals.length - 2] : null;

  const _costDelta     = _haveTrend ? deltaBlock(_latest.cost_usd || 0, _prior.cost_usd || 0, 'bad', false) : '';
  const _sessionsDelta = _haveTrend ? deltaBlock(_latest.sessions || 0, _prior.sessions || 0, 'neutral', false) : '';
  const _turnsDelta    = _haveTrend ? deltaBlock(_latest.turns || 0, _prior.turns || 0, 'neutral', false) : '';
  const _hitDelta      = _haveTrend ? deltaBlock(pointHitRatio(_latest), pointHitRatio(_prior), 'good', true) : '';

  document.getElementById('totals').innerHTML = `
    <div class="headline">
      <div class="label">${labelIcon('cost')}Total cost</div>
      <div class="value">${fmtMoney(totalCost)}</div>
      ${_costDelta}
    </div>
    <div class="metric"><div class="label">${labelIcon('sessions')}Sessions</div><div class="value">${fmtNum(T.Sessions)}</div>${_sessionsDelta}</div>
    <div class="metric"><div class="label">${labelIcon('turns')}Assistant turns</div><div class="value">${fmtNum(T.Turns)}</div>${_turnsDelta}</div>
    <div class="metric"><div class="label">${labelIcon('gauge')}Cache hit ratio</div><div class="value">${hitRatioPill(D.overall_hit_ratio)}</div>${_hitDelta}</div>
  `;

  // ── hotspots ──────────────────────────────────────────────────────────
  (function hotspots() {
    const container = document.getElementById('hotspots');
    const list = D.hotspots || [];
    if (list.length === 0) {
      container.innerHTML = '<p class="small empty-state">No hotspots in this window. Try widening the time range with <code>--since</code>, or lowering <code>-hotspots</code>.</p>';
      return;
    }
    container.innerHTML = list.map((h, i) => {
      // Prompt hotspots get a "view session" affordance when their
      // originating prompt is in the timeline (i.e. inside --sessions=N).
      // Out-of-cap prompts get a disabled-styled hint instead of a broken
      // link.
      let sessionAction = '';
      if (h.kind === 'prompt_pattern' && h.prompt_key) {
        if (promptKeyAvailable.has(h.prompt_key)) {
          sessionAction = `<button class="view-session" data-key="${escHtml(h.prompt_key)}" title="Open the session this prompt ran in">view session →</button>`;
        } else {
          sessionAction = `<span class="view-session is-disabled" title="This prompt's session is below the --sessions=${(D.session_timelines || []).length || 'N'} cap. Re-run with a higher --sessions to include it.">view session (unavailable)</span>`;
        }
      }
      const anchorId = `hotspot-${i+1}`;
      return `<details class="hotspot" id="${anchorId}">
      <summary>
        <span class="rank">#${i+1}</span>
        <span class="hotspot-kind">${escHtml(h.kind.replace(/_/g, ' '))}</span>
        <span class="h-title" title="${escHtml(h.title)}">${escHtml(h.title)}</span>
        <span class="h-cost">${fmtMoney(h.cost_usd)}</span>
        <span class="h-pct">(${h.pct_of_total.toFixed(1)}%)</span>
        <a class="anchor-link" href="#overview/${anchorId}" title="Copy link to this hotspot" aria-label="Copy link to hotspot ${i+1}">#</a>
      </summary>
      <div class="body">
        <div class="actions">
          <button class="copy" data-hotspot="${i}">Copy prompt</button>
          ${sessionAction}
          <span class="small">Paste this into Claude or another LLM for specific advice.</span>
        </div>
        <pre>${escHtml(h.prompt)}</pre>
      </div>
    </details>`;
    }).join('');

    // Wire up cross-link buttons on prompt hotspots.
    container.querySelectorAll('button.view-session').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        jumpToPrompt(btn.dataset.key);
      });
    });

    // Wire up copy buttons. Falls back to the older execCommand path on
    // file:// pages where navigator.clipboard is unavailable.
    container.querySelectorAll('button.copy').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        const idx = parseInt(btn.dataset.hotspot, 10);
        const text = list[idx].prompt;
        let ok = false;
        try {
          if (navigator.clipboard && navigator.clipboard.writeText) {
            await navigator.clipboard.writeText(text);
            ok = true;
          }
        } catch (err) { ok = false; }
        if (!ok) {
          // Fallback: select the <pre> and let the user Cmd-C
          const pre = btn.closest('.body').querySelector('pre');
          const range = document.createRange();
          range.selectNodeContents(pre);
          const sel = window.getSelection();
          sel.removeAllRanges(); sel.addRange(range);
          try { ok = document.execCommand('copy'); } catch { ok = false; }
        }
        const old = btn.textContent;
        btn.textContent = ok ? 'Copied — paste into your LLM' : 'Select & copy manually';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = old; btn.classList.remove('copied'); }, 2200);
      });
    });
  })();

  if (D.unknown_models && D.unknown_models.length) {
    document.getElementById('warnings').innerHTML =
      `<div class="warning-card" role="alert"><strong class="danger">Unpriced models:</strong> ${D.unknown_models.map(escHtml).join(', ')} — add them to <code>~/.config/claudit/prices.yaml</code>.</div>`;
  }

  // ── trend overview section (only when --by is set) ────────────────────
  (function trendSection() {
    const host = document.getElementById('trend-section');
    if (!PERIOD || !D.trend_totals || D.trend_totals.length === 0) return;
    const points = D.trend_totals;

    // Summary stats: peak, mean, last vs prior delta.
    let peak = 0, sum = 0;
    for (const p of points) { if (p.cost_usd > peak) peak = p.cost_usd; sum += p.cost_usd; }
    const mean = sum / points.length;
    let deltaHtml = '';
    if (points.length >= 2) {
      const prev = points[points.length - 2].cost_usd || 0;
      const cur = points[points.length - 1].cost_usd || 0;
      if (prev > 0) {
        const d = 100 * (cur - prev) / prev;
        const cls = d >= 0 ? 'trend-delta-up' : 'trend-delta-down';
        const sign = d >= 0 ? '+' : '';
        deltaHtml = `<span>Latest vs prior: <strong class="${cls}">${sign}${d.toFixed(1)}%</strong></span>`;
      } else if (cur > 0) {
        deltaHtml = `<span>Latest vs prior: <strong>new</strong></span>`;
      }
    }

    // Latest-bucket hit ratio for the summary line.
    const latestHit = pointHitRatio(points[points.length - 1]);

    host.innerHTML = `
      <h2>Cost by ${escHtml(PERIOD)}</h2>
      <div class="small">Spend bucketed by ${escHtml(PERIOD)}. Per-row trend columns below use the same buckets, downsampled to ~30 cells when wider.</div>
      <div class="trend-chart">
        ${trendLineChart(points, PERIOD, D.anomalies)}
        ${hitRatioChart(points, PERIOD, D.anomalies)}
        <div class="trend-summary">
          <span>Buckets: <strong>${points.length}</strong></span>
          <span>Peak: <strong>${escHtml(fmtMoney(peak))}</strong></span>
          <span>Mean: <strong>${escHtml(fmtMoney(mean))}</strong></span>
          <span>Latest hit ratio: <strong>${(latestHit*100).toFixed(1)}%</strong></span>
          ${deltaHtml}
        </div>
      </div>
    `;
  })();

  // Inject Trend column header into by-model / by-project / by-tool when
  // period is on. The Trend column is presentation-only — no data-key, so
  // it isn't sortable.
  function injectTrendColumn(tableSelector, beforeKey) {
    if (!PERIOD) return;
    const table = document.querySelector(tableSelector);
    if (!table) return;
    const headRow = table.querySelector('thead tr');
    const ths = Array.from(headRow.children);
    const idx = ths.findIndex(th => th.dataset.key === beforeKey);
    const th = document.createElement('th');
    th.textContent = 'Trend';
    th.title = 'Per-row sparkline of cost across the report buckets (day/week/month, set by --by). Bars are downsampled to ~30 cells when wider.';
    if (idx >= 0) headRow.insertBefore(th, ths[idx]);
    else headRow.appendChild(th);
  }
  injectTrendColumn('[data-table="model"]', 'OutputTokens');
  injectTrendColumn('[data-table="project"]', 'DominantModel');
  injectTrendColumn('[data-table="tool"]', 'OutputTokens');
  // Cache tables: trend column shows hit ratio over time, placed right
  // after the rolled-up Hit ratio (column key "Miss" sits next to it).
  injectTrendColumn('[data-table="cache-project"]',  'Miss');
  injectTrendColumn('[data-table="cache-session"]',  'Miss');
  injectTrendColumn('[data-table="cache-subagent"]', 'Miss');

  // ── paginated tables ──────────────────────────────────────────────────
  // Each paged table holds its full row data + page/sort state in
  // `tableStates`. renderTable() filters → sorts → slices to current page →
  // builds tbody and updates the pager. Sort, filter, and pager events all
  // call renderTable() rather than mutating DOM directly.
  const PAGE_SIZE = 25;
  const tableStates = new WeakMap();

  function attachHeat(td, value, max) {
    if (max <= 0 || value == null) return;
    td.classList.add('heat');
    td.style.setProperty('--heat',
      Math.min(100, 100 * value / max).toFixed(1) + '%');
  }

  // Insert a trend-sparkline cell at the same column index where
  // injectTrendColumn() placed the header. PERIOD-conditional.
  // Pass `kind: 'hit'` to render a hit-ratio sparkline (0..1 normalized,
  // axis-fixed) instead of the default cost sparkline (max-normalized).
  function withTrend(cells, idx, series, kind) {
    if (!PERIOD) return cells;
    const spark = (kind === 'hit') ? trendSparkHit(series) : trendSpark(series);
    const cell = [`<span class="trend-cell">${spark}</span>`, false];
    return cells.slice(0, idx).concat([cell]).concat(cells.slice(idx));
  }

  // Hit-ratio sparkline. Bars from 0..1 (axis-fixed) so a 30%-hit row
  // reads as visibly shorter bars than a 90%-hit row, even if their max
  // bucket has identical absolute volume. Tooltip on each bar shows the
  // exact ratio for that bucket.
  function trendSparkHit(points, w, h) {
    w = w || 90; h = h || 18;
    if (!points || points.length === 0) return '<span class="small">—</span>';
    const n = points.length;
    const bw = w / n;
    let bars = '';
    for (let i = 0; i < n; i++) {
      const r = pointHitRatio(points[i]);  // 0..1
      const bh = r * (h - 1);
      const x = i * bw;
      const y = h - bh;
      const label = `${escHtml(bucketLabel(points[i].time, PERIOD))}: ${(r * 100).toFixed(1)}% hit`;
      bars += `<rect x="${x.toFixed(2)}" y="${y.toFixed(2)}" width="${(bw*0.85).toFixed(2)}" height="${bh.toFixed(2)}" data-tooltip="${label}"></rect>`;
    }
    return `<svg class="trend-spark" width="${w}" height="${h}" viewBox="0 0 ${w} ${h}">${bars}</svg>`;
  }

  // Build a single lowercased haystack from a row's string fields so the
  // global filter can match any of them without per-call re-stringifying.
  function rowSearchText(r) {
    let s = '';
    for (const k in r) {
      const v = r[k];
      if (typeof v === 'string') s += ' ' + v;
    }
    return s.toLowerCase();
  }

  function getFilterParams() {
    const q = document.getElementById('filter').value.trim().toLowerCase();
    const minCost = parseFloat(document.getElementById('mincost').value || '0') || 0;
    return { q, minCost };
  }

  function filterRows(st) {
    const { q, minCost } = getFilterParams();
    return st.rows.filter(r => {
      if (minCost > 0 && (r.CostUSD || 0) < minCost) return false;
      if (q && !rowSearchText(r).includes(q)) return false;
      return true;
    });
  }

  function sortRows(rows, key, dir) {
    if (!key || !rows.length || !(key in rows[0])) return rows;
    const sign = dir === 'asc' ? 1 : -1;
    return [...rows].sort((a, b) => {
      const av = a[key], bv = b[key];
      if (av == null && bv == null) return 0;
      if (av == null) return sign;
      if (bv == null) return -sign;
      if (typeof av === 'number' && typeof bv === 'number') {
        return sign * (av - bv);
      }
      return sign * String(av).localeCompare(String(bv));
    });
  }

  function ensurePager(table) {
    let pager = table.parentNode.querySelector(
      `:scope > .pager[data-pager-for="${table.dataset.table}"]`);
    if (pager) return pager;
    pager = document.createElement('div');
    pager.className = 'pager';
    pager.dataset.pagerFor = table.dataset.table;
    pager.innerHTML = `
      <button class="pager-btn" data-pager-action="prev" aria-label="Previous page">‹ Prev</button>
      <span class="pager-info">
        <span class="pager-page">Page <strong class="pager-cur">1</strong> / <strong class="pager-total">1</strong></span>
        <span class="pager-count">0 entries</span>
      </span>
      <button class="pager-btn" data-pager-action="next" aria-label="Next page">Next ›</button>
    `;
    table.parentNode.insertBefore(pager, table.nextSibling);
    pager.querySelector('[data-pager-action="prev"]').addEventListener('click', () => {
      const st = tableStates.get(table);
      if (st && st.page > 0) { st.page--; renderTable(table); }
    });
    pager.querySelector('[data-pager-action="next"]').addEventListener('click', () => {
      const st = tableStates.get(table);
      if (!st) return;
      const totalPages = Math.max(1, Math.ceil(filterRows(st).length / st.pageSize));
      if (st.page < totalPages - 1) { st.page++; renderTable(table); }
    });
    return pager;
  }

  function renderTable(table) {
    const st = tableStates.get(table);
    if (!st) return;

    const filtered = filterRows(st);
    const sorted = sortRows(filtered, st.sortKey, st.sortDir);
    const totalRows = sorted.length;
    const totalPages = Math.max(1, Math.ceil(totalRows / st.pageSize));
    if (st.page >= totalPages) st.page = totalPages - 1;
    if (st.page < 0) st.page = 0;
    const pageRows = sorted.slice(st.page * st.pageSize, (st.page + 1) * st.pageSize);

    // Heat scales per-column: a column's overlay maxes at the largest
    // heatVal seen in that column among filtered rows. This keeps the
    // Miss-tokens column from being scaled against CostUSD (which would
    // always clip to 100%).
    const heatMax = {};
    filtered.forEach(r => {
      const cells = st.mapper(r);
      cells.forEach((c, i) => {
        const v = c[2];
        if (v != null && v > 0) {
          heatMax[i] = Math.max(heatMax[i] || 0, v);
        }
      });
    });

    const tbody = table.querySelector('tbody');
    tbody.innerHTML = '';

    if (totalRows === 0) {
      const colCount = table.querySelectorAll('thead th').length;
      tbody.innerHTML = `<tr><td colspan="${colCount}" class="empty-state-row">No matching rows.</td></tr>`;
    } else {
      pageRows.forEach(r => {
        const tr = document.createElement('tr');
        tr.dataset.cost = r.CostUSD || 0;
        const cells = st.mapper(r);
        cells.forEach(([html, isNum, heatVal], i) => {
          const td = document.createElement('td');
          if (isNum) td.classList.add('num');
          td.innerHTML = html;
          if (heatVal != null) attachHeat(td, heatVal, heatMax[i] || 0);
          tr.appendChild(td);
        });
        tbody.appendChild(tr);
      });
    }

    // Pager: hide entirely when total fits on a single page.
    const pager = ensurePager(table);
    pager.querySelector('.pager-cur').textContent = totalRows === 0 ? 0 : st.page + 1;
    pager.querySelector('.pager-total').textContent = totalRows === 0 ? 0 : totalPages;
    pager.querySelector('.pager-count').textContent =
      totalRows + (totalRows === 1 ? ' entry' : ' entries');
    pager.querySelector('[data-pager-action="prev"]').disabled = st.page <= 0 || totalRows === 0;
    pager.querySelector('[data-pager-action="next"]').disabled =
      st.page >= totalPages - 1 || totalRows === 0;
    pager.style.display = totalRows > st.pageSize ? '' : 'none';

    // Sort indicators on header cells.
    table.querySelectorAll('thead th').forEach(h =>
      h.classList.remove('sorted-asc', 'sorted-desc'));
    if (st.sortKey) {
      const th = table.querySelector(`thead th[data-key="${st.sortKey}"]`);
      if (th) th.classList.add(st.sortDir === 'asc' ? 'sorted-asc' : 'sorted-desc');
    }
  }

  // Public callers retain the same `buildRows(table, rows, mapper)` signature.
  function buildRows(table, rows, mapper) {
    tableStates.set(table, {
      rows, mapper,
      pageSize: PAGE_SIZE,
      page: 0,
      sortKey: null,
      sortDir: null,
    });
    renderTable(table);
  }

  // By model
  buildRows(document.querySelector('[data-table="model"]'), D.by_model || [], r => withTrend([
    [escHtml(r.Model), false],
    [fmtMoney(r.CostUSD), true, r.CostUSD],
    [fmtPct(r.CostUSD, totalCost), true],
    [fmtNum(r.Turns), true],
    [fmtNum(r.OutputTokens), true],
    [fmtNum(r.CacheReadTokens), true],
  ], 4, (D.trend_by_model || {})[r.Model]));

  // Horizontal bar list for by-model. Same pattern as by-project / by-tool —
  // one share-viz vocabulary across the page.
  (function modelBars() {
    const host = document.getElementById('bars-model');
    const rows = (D.by_model || []).filter(r => r.CostUSD > 0);
    if (rows.length === 0) {
      host.innerHTML = '<p class="small empty-state">No priced model data. Add prices for any unknown models in <code>~/.config/claudit/prices.yaml</code>.</p>';
      return;
    }
    const maxCost = Math.max(0, ...rows.map(r => r.CostUSD));
    host.innerHTML = rows.map(r => {
      const w = maxCost > 0 ? (100 * r.CostUSD / maxCost).toFixed(1) : 0;
      return `<div class="hbar">
        <div class="fill" style="width:${w}%"></div>
        <div class="lbl" title="${escHtml(r.Model)}">${escHtml(r.Model)}</div>
        <div class="val">${fmtMoney(r.CostUSD)} (${fmtPct(r.CostUSD, totalCost)})</div>
      </div>`;
    }).join('');
  })();

  // By project
  buildRows(document.querySelector('[data-table="project"]'), D.by_project || [], r => withTrend([
    [`<span class="truncate path" title="${escHtml(r.Project)}">${escHtml(r.Project)}</span>`, false],
    [fmtMoney(r.CostUSD), true, r.CostUSD],
    [fmtPct(r.CostUSD, totalCost), true],
    [fmtNum(r.Sessions), true],
    [fmtNum(r.Turns), true],
    [escHtml(r.DominantModel), false],
  ], 5, (D.trend_by_project || {})[r.Project]));

  // Horizontal bar list — top 20 projects
  (function projectBars() {
    const rows = (D.by_project || []).slice(0, 20);
    const maxCost = Math.max(0, ...rows.map(r => r.CostUSD));
    document.getElementById('bars-project').innerHTML = rows.map(r => {
      const w = maxCost > 0 ? (100 * r.CostUSD / maxCost).toFixed(1) : 0;
      return `<div class="hbar">
        <div class="fill" style="width:${w}%"></div>
        <div class="lbl" title="${escHtml(r.Project)}">${escHtml(truncate(r.Project, 70))}</div>
        <div class="val">${fmtMoney(r.CostUSD)} (${fmtPct(r.CostUSD, totalCost)})</div>
      </div>`;
    }).join('');
  })();

  // Cache efficiency: project + session worst-offender tables. Sorted
  // server-side by miss tokens desc; we just render.
  (function cacheSection() {
    const proj = D.cache_by_project || [];
    const sess = D.cache_by_session || [];
    let totalMiss = 0;
    for (const r of proj) totalMiss += r.Miss || 0;
    document.getElementById('cache-summary').innerHTML = `
      <span>Overall hit ratio: ${hitRatioPill(D.overall_hit_ratio)}</span>
      <span>Total miss tokens: <strong>${fmtNum(totalMiss)}</strong></span>
      <span>Projects with cacheable traffic: <strong>${proj.length}</strong></span>
      <span>Sessions with cacheable traffic: <strong>${sess.length}</strong></span>
    `;

    buildRows(document.querySelector('[data-table="cache-project"]'), proj, r => withTrend([
      [`<span class="truncate path" title="${escHtml(r.Key)}">${escHtml(r.Key)}</span>`, false],
      [hitRatioPill(r.HitRatio), true],
      [fmtNum(r.Miss), true, r.Miss],
      [fmtNum(r.CacheReadTokens), true],
      [fmtNum(r.Turns), true],
      [fmtMoney(r.CostUSD), true],
    ], 2, (D.trend_by_project || {})[r.Key], 'hit'));

    buildRows(document.querySelector('[data-table="cache-session"]'), sess, r => withTrend([
      [`<code>${escHtml((r.Key || '').slice(0, 8))}…</code>`, false],
      [`<span class="truncate path" title="${escHtml(r.Subtitle)}">${escHtml(truncate(r.Subtitle || '', 80))}</span>`, false],
      [hitRatioPill(r.HitRatio), true],
      [fmtNum(r.Miss), true, r.Miss],
      [fmtNum(r.CacheReadTokens), true],
      [fmtNum(r.Turns), true],
      [fmtMoney(r.CostUSD), true],
    ], 3, (D.trend_by_session || {})[r.Key], 'hit'));

    const subs = D.cache_by_subagent || [];
    buildRows(document.querySelector('[data-table="cache-subagent"]'), subs, r => withTrend([
      [escHtml(r.Key), false],
      [hitRatioPill(r.HitRatio), true],
      [fmtNum(r.Miss), true, r.Miss],
      [fmtNum(r.CacheReadTokens), true],
      [fmtNum(r.Turns), true],
      [fmtMoney(r.CostUSD), true],
    ], 2, (D.trend_by_subagent || {})[r.Key], 'hit'));

    const invs = D.cache_by_invocation || [];
    buildRows(document.querySelector('[data-table="cache-invocation"]'), invs, r => [
      [`<span class="truncate" title="${escHtml(r.Key)}">${escHtml(truncate(r.Key, 80))}</span>`, false],
      [escHtml(r.Subtitle || '(unknown)'), false],
      [hitRatioPill(r.HitRatio), true],
      [fmtNum(r.Miss), true, r.Miss],
      [fmtNum(r.CacheReadTokens), true],
      [fmtNum(r.Turns), true],
      [fmtMoney(r.CostUSD), true],
    ]);
  })();

  // By tool
  buildRows(document.querySelector('[data-table="tool"]'), D.by_tool || [], r => withTrend([
    [escHtml(r.Name), false],
    [fmtNum(r.Count), true],
    [fmtNum(r.TurnCount), true],
    [fmtMoney(r.CostUSD), true, r.CostUSD],
    [fmtPct(r.CostUSD, totalCost), true],
    [fmtNum(r.OutputTokens), true],
  ], 5, (D.trend_by_tool || {})[r.Name]));

  // Tool bars
  (function toolBars() {
    const rows = D.by_tool || [];
    const maxCost = Math.max(0, ...rows.map(r => r.CostUSD));
    document.getElementById('bars-tool').innerHTML = rows.map(r => {
      const w = maxCost > 0 ? (100 * r.CostUSD / maxCost).toFixed(1) : 0;
      return `<div class="hbar">
        <div class="fill" style="width:${w}%"></div>
        <div class="lbl">${escHtml(r.Name)}</div>
        <div class="val">${fmtMoney(r.CostUSD)} · ${fmtNum(r.Count)} calls</div>
      </div>`;
    }).join('');
  })();

  // Drill-down per tool
  (function drill() {
    const det = D.by_tool_detail || {};
    const tools = (D.by_tool || []).filter(t => det[t.Name] && det[t.Name].length);
    const container = document.getElementById('drill-container');
    container.innerHTML = tools.map(tool => {
      const rows = det[tool.Name];
      const max = tool.CostUSD || 1;
      const tbody = rows.slice(0, 50).map(r => `<tr data-cost="${r.CostUSD}">
        <td><code>${escHtml(r.Detail)}</code></td>
        <td class="num">${fmtNum(r.Count)}</td>
        <td class="num">${fmtNum(r.TurnCount)}</td>
        <td class="num heat" style="--heat:${Math.min(100,100*r.CostUSD/max).toFixed(1)}%">${fmtMoney(r.CostUSD)}</td>
        <td class="num">${fmtPct(r.CostUSD, tool.CostUSD)}</td>
        <td class="num">${fmtNum(r.OutputTokens)}</td>
      </tr>`).join('');
      const more = rows.length > 50 ? `<tr><td colspan="6" class="small"><em>${rows.length - 50} more rows hidden — use the JSON output (<code>--json</code>) for the full list.</em></td></tr>` : '';
      return `<details class="tool-drill" data-table="drill-${escHtml(tool.Name)}">
        <summary>${escHtml(tool.Name)} <span class="small">— ${fmtMoney(tool.CostUSD)} across ${fmtNum(tool.Count)} call(s) · ${rows.length} pattern(s)</span></summary>
        <table>
          <thead><tr>
            <th data-key="Detail">Pattern</th>
            <th data-key="Count" class="num">Calls</th>
            <th data-key="TurnCount" class="num">Turns</th>
            <th data-key="CostUSD" class="num">Cost</th>
            <th data-key="Pct" class="num">% of ${escHtml(tool.Name)}</th>
            <th data-key="OutputTokens" class="num">Output tokens</th>
          </tr></thead>
          <tbody>${tbody}${more}</tbody>
        </table>
      </details>`;
    }).join('');
  })();

  // Top expensive prompts. Sample is the full text; show the head as the
  // visible snippet, full text on hover. Trailing cell is a "view session"
  // cross-link active when the prompt's session is in the timeline cap.
  buildRows(document.querySelector('[data-table="prompt"]'), D.by_prompt || [], r => {
    const sample = r.Sample || r.Key || '';
    const head = sample.length > 80 ? sample.slice(0, 79) + '…' : sample;
    let sessionCell;
    if (r.Key && promptKeyAvailable.has(r.Key)) {
      sessionCell = `<button class="view-session" data-key="${escHtml(r.Key)}" title="Jump to this prompt in the Sessions view">view →</button>`;
    } else {
      sessionCell = `<span class="view-session is-disabled" title="Session below the --sessions=N cap, or orphan prompt with no recognized origin">—</span>`;
    }
    return [
      [`<span title="${escHtml(sample)}">${escHtml(head)}</span>`, false],
      [fmtNum(r.Invocations), true],
      [fmtNum(r.Sessions), true],
      [fmtNum(r.TurnCount), true],
      [fmtMoney(r.CostUSD), true, r.CostUSD],
      [fmtPct(r.CostUSD, totalCost), true],
      [sessionCell, false],
    ];
  });

  // Delegated click handler for the per-prompt "view session" buttons.
  // Delegated rather than bound per-row because buildRows() may paginate /
  // re-render rows (search filter, sort) and we don't want to re-bind.
  document.querySelector('[data-table="prompt"]')?.addEventListener('click', (e) => {
    const btn = e.target.closest('button.view-session');
    if (!btn) return;
    e.preventDefault();
    jumpToPrompt(btn.dataset.key);
  });

  // By skill
  buildRows(document.querySelector('[data-table="skill"]'), D.by_skill || [], r => [
    [`<code>${escHtml(r.Key)}</code>`, false],
    [fmtNum(r.Count), true],
    [fmtNum(r.TurnCount), true],
    [fmtMoney(r.CostUSD), true, r.CostUSD],
    [fmtNum(r.OutputTokens), true],
  ]);

  // Main vs sidechain stacked bar + table
  (function mainSide() {
    const main = D.main || {cost:0,turns:0,tokens:{}};
    const side = D.sidechain || {cost:0,turns:0,tokens:{}};
    const total = main.cost + side.cost;
    const stacked = document.getElementById('stacked-main');
    if (total > 0) {
      const mp = 100 * main.cost / total, sp = 100 - mp;
      stacked.innerHTML = `
        <div class="bucket bucket-main" style="width:${mp}%" title="main: ${fmtMoney(main.cost)}">main · ${mp.toFixed(1)}%</div>
        <div class="bucket bucket-side" style="width:${sp}%" title="sidechain: ${fmtMoney(side.cost)}">sidechain · ${sp.toFixed(1)}%</div>`;
    }
    const tbody = document.querySelector('[data-table="mainside"] tbody');
    const buckets = [
      ['main', main.cost, main.turns, (main.tokens||{}).CacheReadTokens],
      ['sidechain', side.cost, side.turns, (side.tokens||{}).CacheReadTokens],
    ];
    tbody.innerHTML = buckets.map(([n, c, t, cr]) =>
      `<tr data-cost="${c}"><td>${n}</td><td class="num">${fmtMoney(c)}</td><td class="num">${fmtPct(c, total)}</td><td class="num">${fmtNum(t)}</td><td class="num">${fmtNum(cr)}</td></tr>`
    ).join('');
  })();

  // By subagent
  buildRows(document.querySelector('[data-table="subagent"]'), D.by_subagent || [], r => [
    [escHtml(r.Type), false],
    [fmtMoney(r.CostUSD), true, r.CostUSD],
    [fmtPct(r.CostUSD, sideCost), true],
    [fmtNum(r.Turns), true],
    [fmtNum(r.OutputTokens), true],
    [fmtNum(r.CacheReadTokens), true],
  ]);

  // Agent invocations
  buildRows(document.querySelector('[data-table="invocation"]'), D.agent_invocations || [], r => [
    [escHtml(r.SubagentType || '(unknown)'), false],
    [`<span title="${escHtml(r.Description)}">${escHtml(truncate(r.Description, 80))}</span>`, false],
    [fmtMoney(r.CostUSD), true, r.CostUSD],
    [fmtNum(r.Turns), true],
    [`<span class="truncate path" title="${escHtml(r.Project)}">${escHtml(truncate(r.Project, 80))}</span>`, false],
    [fmtDate(r.First), false],
  ]);

  // ── sorting ───────────────────────────────────────────────────────────
  // Click a th[data-key] to sort the underlying data array; default is
  // descending (biggest first), repeat click flips direction.
  document.querySelectorAll('table thead th[data-key]').forEach(th => {
    th.addEventListener('click', () => {
      const table = th.closest('table');
      const st = tableStates.get(table);
      if (!st) return;  // unpaged tables (e.g. mainside) ignore clicks
      const key = th.dataset.key;
      // The injected Trend column has no underlying field — skip silently.
      if (st.rows.length && !(key in st.rows[0])) return;
      if (st.sortKey === key) {
        st.sortDir = st.sortDir === 'asc' ? 'desc' : 'asc';
      } else {
        st.sortKey = key;
        st.sortDir = 'desc';
      }
      st.page = 0;
      renderTable(table);
    });
  });

  // ── global filter + min cost ──────────────────────────────────────────
  // Paged tables re-render against the filter; drill-down internals (which
  // are render-once + capped) keep using the older class-based hide.
  function applyFilters() {
    document.querySelectorAll('table[data-table]').forEach(table => {
      const st = tableStates.get(table);
      if (!st) return;
      st.page = 0;
      renderTable(table);
    });
    const { q, minCost } = getFilterParams();
    document.querySelectorAll('details tbody tr').forEach(tr => {
      const cost = parseFloat(tr.dataset.cost || '0');
      const text = tr.textContent.toLowerCase();
      const matches = (!q || text.includes(q)) && (cost >= minCost);
      tr.classList.toggle('hidden', !matches);
    });
  }
  document.getElementById('filter').addEventListener('input', applyFilters);
  document.getElementById('mincost').addEventListener('input', applyFilters);

  // ── sessions drill-down ───────────────────────────────────────────────
  // Each session in D.session_timelines becomes a nested <details>: outer
  // = session card (collapsed), inner = prompt (collapsed), revealing a
  // per-turn list. Costs/tokens are pre-aggregated by the backend so the
  // renderer is mostly string-shaping.
  (function renderSessions() {
    const host = document.getElementById('session-list');
    const empty = document.getElementById('session-empty');
    if (!host) return;
    const data = D.session_timelines || [];
    if (data.length === 0) {
      empty && (empty.hidden = false);
      return;
    }

    // Surface --redact state in the guide so users know prompt text was
    // intentionally hidden — otherwise "[redacted N chars]" reads as a bug.
    const anyRedacted = data.some(s =>
      (s.Prompts || []).some(p => typeof p.Text === 'string' && p.Text.startsWith('[redacted ')));
    if (anyRedacted) {
      const notice = document.getElementById('session-redact-notice');
      if (notice) notice.textContent =
        'Prompts in this report were redacted at generation time (--redact). Costs and tokens are unaffected.';
    }

    const fmtTime = ts => {
      if (!ts) return '';
      const d = new Date(ts);
      if (isNaN(d.getTime())) return '';
      // Local time. YYYY-MM-DD HH:MM is enough resolution for drill-down.
      const pad = n => String(n).padStart(2, '0');
      return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
    };
    const fmtHMS = ts => {
      if (!ts) return '';
      const d = new Date(ts);
      if (isNaN(d.getTime())) return '';
      const pad = n => String(n).padStart(2, '0');
      return `${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
    };
    // Natural-language span between two timestamps. Default unit is
    // minutes; <60s renders as seconds; ≥1h escalates to h+m+s; ≥1d adds
    // days. Returns empty string for invalid or zero-length spans.
    const fmtSpan = (start, end) => {
      if (!start || !end) return '';
      const a = new Date(start), b = new Date(end);
      if (isNaN(a.getTime()) || isNaN(b.getTime())) return '';
      let s = Math.max(0, Math.round((b.getTime() - a.getTime()) / 1000));
      if (s === 0) return '';
      if (s < 60) return `${s}s`;
      const d = Math.floor(s / 86400); s -= d * 86400;
      const h = Math.floor(s / 3600);  s -= h * 3600;
      const m = Math.floor(s / 60);    s -= m * 60;
      const parts = [];
      if (d > 0) parts.push(`${d}d`);
      if (h > 0) parts.push(`${h}h`);
      if (h > 0 || m > 0) parts.push(`${m}m`);
      if (h > 0 && s > 0) parts.push(`${s}s`); // only surface seconds when h is present
      return parts.join(' ');
    };
    const sumTokens = tk => (
      (tk.InputTokens || 0) + (tk.OutputTokens || 0) +
      (tk.CacheCreate5mTokens || 0) + (tk.CacheCreate1hTokens || 0) +
      (tk.CacheReadTokens || 0)
    );
    const fmtCount = n => n >= 1000 ? (n/1000).toFixed(1) + 'k' : String(n);
    const fmtTokens = tk => {
      const inT = tk.InputTokens || 0;
      const outT = tk.OutputTokens || 0;
      return `${fmtCount(inT)} in · ${fmtCount(outT)} out`;
    };
    // Cache total = read + 5m create + 1h create. The single number is
    // what makes "3 in · 1 out · $0.07" intelligible — the cost came from
    // a big cache read, not the visible input. Tooltip splits read vs create
    // so the user can see whether they're paying for a hit or a miss.
    const fmtCache = tk => {
      const r = tk.CacheReadTokens || 0;
      const c5 = tk.CacheCreate5mTokens || 0;
      const c1 = tk.CacheCreate1hTokens || 0;
      const total = r + c5 + c1;
      if (total === 0) return '';
      const parts = [];
      if (r > 0) parts.push(`${fmtCount(r)} read`);
      if (c5 > 0) parts.push(`${fmtCount(c5)} create 5m`);
      if (c1 > 0) parts.push(`${fmtCount(c1)} create 1h`);
      return `<span class="t-cache" title="${escHtml(parts.join(', '))}">${fmtCount(total)} cache</span>`;
    };
    // Deterministic color slot 1-5 for a tool name (Notion-style tag
     // coloring). Same name → same color across the whole report, so the
     // user can scan for "all the Bash pills" by hue alone. Uses a small
     // FNV-1a hash so trivial name swaps don't all land on the same slot.
    const toolColorSlot = name => {
      if (!name) return 0;
      let h = 0x811c9dc5;
      for (let i = 0; i < name.length; i++) {
        h ^= name.charCodeAt(i);
        h = Math.imul(h, 0x01000193) >>> 0;
      }
      return (h % 5) + 1;
    };
    // Duration formatter — backend gives ms. Show ms under 1s, then s, then
    // m+s. We never show "0" — zero means "no successor turn" (last in
    // prompt) and the caller suppresses the slot entirely.
    const fmtDuration = ms => {
      if (!ms || ms <= 0) return '';
      if (ms < 1000) return `${ms}ms`;
      const sec = ms / 1000;
      if (sec < 60) return `${sec < 10 ? sec.toFixed(1) : Math.round(sec)}s`;
      const m = Math.floor(sec / 60);
      const s = Math.round(sec - m * 60);
      return s === 0 ? `${m}m` : `${m}m${s}s`;
    };

    // First non-orphan prompt's text, single-lined and truncated to 80
    // chars. Serves as a human-readable "title" for the session card —
    // far more useful at a glance than the opaque UUID. Returns null when
    // no usable prompt exists (orphans only, or redacted bodies).
    const firstPromptPreview = s => {
      for (const p of (s.Prompts || [])) {
        if (!p.UUID) continue;
        const raw = (p.Text || '').replace(/\s+/g, ' ').trim();
        if (!raw) continue;
        if (raw.startsWith('[redacted ')) return raw;
        return raw.length > 80 ? raw.slice(0, 80) + '…' : raw;
      }
      return null;
    };

    const html = [];
    data.forEach((s, idx) => {
      const sid = s.SessionID || '(unknown)';
      const promptCount = (s.Prompts || []).length;
      const span = fmtSpan(s.StartedAt, s.EndedAt);
      const timeRange = span
        ? `${fmtTime(s.StartedAt)} → ${fmtTime(s.EndedAt)} (${span})`
        : `${fmtTime(s.StartedAt)} → ${fmtTime(s.EndedAt)}`;
      // Rotate through the 5-color palette per session card. Index-based
      // (not hashed) so adjacent cards always differ — the user asked
      // explicitly for "alternating," and round-robin is the cleanest
      // realization of that.
      const sidSlot = (idx % 5) + 1;
      const preview = firstPromptPreview(s);

      const anchorId = `session-${sid}`;
      html.push(`<details class="session-card" id="${escHtml(anchorId)}" data-session="${escHtml(sid)}">`);
      html.push(`<summary>`);
      html.push(`<span class="s-id" data-c="${sidSlot}" title="${escHtml(sid)}">${escHtml(sid)}</span>`);
      html.push(`<span class="s-cwd" title="${escHtml(s.CWD || '')}">${escHtml(s.CWD || '—')}</span>`);
      html.push(`<span class="s-stats">`);
      html.push(`<span>${promptCount} prompt${promptCount===1?'':'s'}</span>`);
      html.push(`<span>${s.Turns || 0} turn${s.Turns===1?'':'s'}</span>`);
      html.push(`<span class="s-cost">${escHtml(fmtMoney(s.CostUSD || 0))}</span>`);
      html.push(`<a class="anchor-link" href="#sessions/${escHtml(anchorId)}" title="Copy link to this session" aria-label="Copy link to session">#</a>`);
      html.push(`</span>`);
      if (preview) {
        html.push(`<span class="s-preview" title="${escHtml(preview)}">${escHtml(preview)}</span>`);
      } else {
        html.push(`<span class="s-preview is-empty">(no recognizable user prompts)</span>`);
      }
      html.push(`<span class="s-time">${escHtml(timeRange)}</span>`);
      html.push(`</summary>`);
      html.push(`<div class="session-body">`);

      for (const p of (s.Prompts || [])) {
        const text = p.Text || '';
        const isRedacted = text.startsWith('[redacted ');
        const isOrphan = !p.UUID;
        const promptCost = p.CostUSD || 0;
        const turnN = (p.Turns || []).length;
        const keyAttr = p.Key ? ` data-prompt-key="${escHtml(p.Key)}"` : '';

        html.push(`<details class="prompt-block"${isOrphan ? ' data-orphan="1"' : ''}${keyAttr}>`);
        html.push(`<summary>`);
        if (isOrphan) {
          html.push(`<span class="p-text p-redacted">(orphan turns — no recognized originating prompt)</span>`);
        } else if (isRedacted) {
          html.push(`<span class="p-text p-redacted">${escHtml(text)}</span>`);
        } else {
          html.push(`<span class="p-text">${escHtml(text)}</span>`);
        }
        html.push(`<span class="p-stats">`);
        html.push(`<span>${turnN} turn${turnN===1?'':'s'}</span>`);
        html.push(`<span class="p-cost">${escHtml(fmtMoney(promptCost))}</span>`);
        html.push(`</span>`);
        html.push(`</summary>`);

        if (p.Truncated) {
          html.push(`<div class="p-truncated">(prompt truncated — re-run with a higher --sessions cap or check the raw JSONL for the full text)</div>`);
        }

        html.push(`<ul class="turn-list">`);
        for (const t of (p.Turns || [])) {
          html.push(`<li class="turn-row">`);
          const dur = fmtDuration(t.DurationMs || 0);
          const durHtml = dur
            ? ` <span class="t-dur" title="Time to next turn within this prompt">${escHtml(dur)}</span>`
            : '';
          html.push(`<span class="t-time">${escHtml(fmtHMS(t.Timestamp))}${durHtml}</span>`);
          html.push(`<span class="t-model" title="${escHtml(t.Model || '')}">${escHtml(t.Model || '—')}</span>`);
          const cache = fmtCache(t.Tokens || {});
          html.push(`<span class="t-tokens">${escHtml(fmtTokens(t.Tokens || {}))}${cache ? ' · ' + cache : ''}</span>`);
          html.push(`<span class="t-cost">${escHtml(fmtMoney(t.CostUSD || 0))}</span>`);
          html.push(`<span class="t-tools">`);
          for (const tool of (t.Tools || [])) {
            const name = tool.Name || '';
            const detail = tool.Detail || '';
            const label = detail
              ? `${escHtml(name)} · <span class="t-tool-detail">${escHtml(detail)}</span>`
              : escHtml(name);
            const titleAttr = detail ? ` title="${escHtml(name + ' · ' + detail)}"` : '';
            const slot = toolColorSlot(name);
            html.push(`<span class="t-tool" data-c="${slot}"${titleAttr}>${label}</span>`);
          }
          if (t.Sidechain) html.push(`<span class="t-side">sidechain</span>`);
          html.push(`</span>`);
          html.push(`</li>`);
        }
        html.push(`</ul>`);
        html.push(`</details>`);
      }
      html.push(`</div>`);
      html.push(`</details>`);
    });
    host.innerHTML = html.join('');
  })();

  // ── sidebar metrics ───────────────────────────────────────────────────
  // The sidebar carries each section's headline number so the nav itself
  // works as a glanceable summary, not just a list of words.
  (function navMetrics() {
    const set = (id, text) => {
      const el = document.getElementById(id);
      if (el) el.textContent = text;
    };

    // Overview — total cost.
    set('nav-metric-overview', fmtMoney(totalCost));

    // Cost — top model by spend.
    const topModel = (D.by_model || []).filter(r => r.CostUSD > 0)[0];
    set('nav-metric-cost', topModel
      ? `${truncate(topModel.Model, 18)} · ${fmtMoney(topModel.CostUSD)}`
      : '—');

    // Sessions — count shown + cost of the top session, so the user knows
    // at a glance how rich the drill-down is.
    const sessions = D.session_timelines || [];
    if (sessions.length > 0) {
      const top = sessions[0];
      set('nav-metric-sessions', `${sessions.length} · top ${fmtMoney(top.CostUSD || 0)}`);
    } else {
      set('nav-metric-sessions', '—');
    }

    // Cache — overall hit ratio. Uses HTML for the colored tier pill.
    const cacheNav = document.getElementById('nav-metric-cache');
    if (cacheNav) {
      cacheNav.innerHTML = D.overall_hit_ratio != null
        ? hitRatioPill(D.overall_hit_ratio, 'tier-sm') + ' <span class="small">hit</span>'
        : '—';
    }

    // Tools — top tool by cost.
    const topTool = (D.by_tool || [])[0];
    set('nav-metric-tools', topTool
      ? `${truncate(topTool.Name, 14)} · ${fmtMoney(topTool.CostUSD)}`
      : '—');

    // Subagents — sidechain share of total spend.
    set('nav-metric-subagents',
      totalCost > 0
        ? `${fmtMoney(sideCost)} · ${fmtPct(sideCost, totalCost)}`
        : '—');
  })();

  // ── custom tooltip ─────────────────────────────────────────────────────
  // Single floating element repositioned to whichever [title]/[data-tooltip]
  // the cursor is over. We migrate `title` → `data-tooltip` on each element
  // so the native browser tooltip stays suppressed (otherwise both render).
  (function tooltips() {
    if (!window.matchMedia) return;
    // Skip on touch devices — there's no hover affordance, and the
    // popover would interfere with tap-to-sort on column headers.
    if (window.matchMedia('(hover: none)').matches) return;

    const tip = document.createElement('div');
    tip.id = 'claudit-tooltip';
    tip.setAttribute('role', 'tooltip');
    document.body.appendChild(tip);

    let showTimer = null;
    let hideTimer = null;
    let activeEl = null;

    function captureTitles(root) {
      // Move title="" → data-tooltip="" so native tooltip is suppressed
      // but the text remains discoverable for our handler.
      root.querySelectorAll('[title]').forEach(el => {
        if (!el.dataset.tooltip) el.dataset.tooltip = el.getAttribute('title');
        el.removeAttribute('title');
      });
    }
    captureTitles(document);

    // Re-capture after dynamic table renders inject new <th> nodes.
    const mo = new MutationObserver(() => captureTitles(document));
    mo.observe(document.body, { childList: true, subtree: true });

    function position(el) {
      const r = el.getBoundingClientRect();
      const tipR = tip.getBoundingClientRect();
      const margin = 10;
      // Default above; flip below if no room.
      let top = r.top - tipR.height - margin;
      let side = 'top';
      if (top < 6) {
        top = r.bottom + margin;
        side = 'bottom';
      }
      // Center horizontally on the target, clamp to viewport.
      let left = r.left + r.width / 2 - tipR.width / 2;
      left = Math.max(6, Math.min(left, window.innerWidth - tipR.width - 6));
      const arrowX = (r.left + r.width / 2) - left;
      tip.style.top  = `${Math.round(top)}px`;
      tip.style.left = `${Math.round(left)}px`;
      tip.style.setProperty('--arrow-x', `${Math.round(arrowX)}px`);
      tip.dataset.side = side;
    }

    function show(el) {
      const text = el.dataset.tooltip;
      if (!text) return;
      activeEl = el;
      // Lightweight markdown: backticks → <code>. Everything else escaped.
      const safe = text.replace(/[&<>]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]))
                       .replace(/`([^`]+)`/g, '<code>$1</code>');
      tip.innerHTML = safe;
      tip.classList.add('is-visible');
      // Two-frame trick: render → measure → position → reveal.
      requestAnimationFrame(() => requestAnimationFrame(() => {
        if (activeEl === el) position(el);
      }));
    }
    function hide() {
      tip.classList.remove('is-visible');
      activeEl = null;
    }

    function onEnter(e) {
      const el = e.target.closest('[data-tooltip]');
      if (!el) return;
      clearTimeout(hideTimer);
      clearTimeout(showTimer);
      showTimer = setTimeout(() => show(el), 220);
    }
    function onLeave(e) {
      const el = e.target.closest('[data-tooltip]');
      if (!el) return;
      clearTimeout(showTimer);
      hideTimer = setTimeout(hide, 80);
    }
    document.addEventListener('mouseover', onEnter);
    document.addEventListener('mouseout', onLeave);
    document.addEventListener('focusin',  e => {
      const el = e.target.closest('[data-tooltip]');
      if (el) show(el);
    });
    document.addEventListener('focusout', e => {
      const el = e.target.closest('[data-tooltip]');
      if (el) hide();
    });
    window.addEventListener('scroll',  hide, true);
    window.addEventListener('resize',  hide);
    // Re-position on viewport resize while visible (rare).
    window.addEventListener('keydown', e => { if (e.key === 'Escape') hide(); });
  })();

  // ── motion polish ──────────────────────────────────────────────────────
  // Number count-up on the totals headline + chart line draw-on. Both
  // respect prefers-reduced-motion (CSS guards animation; JS bails early).
  (function motion() {
    const reduce = window.matchMedia &&
                   window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) return;

    // Headline cost count-up. Reads target from textContent and replays
    // it from a low fraction up to full value over ~700ms.
    const headline = document.querySelector('.totals .headline .value');
    if (headline) {
      const finalText = headline.textContent;
      const target = totalCost;
      if (target > 0) {
        headline.classList.add('cl-counting');
        const start = performance.now();
        const dur = 700;
        function tick(now) {
          const t = Math.min(1, (now - start) / dur);
          const eased = 1 - Math.pow(1 - t, 3);  // ease-out cubic
          const v = target * eased;
          headline.textContent = v >= 1000
            ? '$' + Math.round(v).toLocaleString()
            : '$' + v.toFixed(2);
          if (t < 1) requestAnimationFrame(tick);
          else { headline.textContent = finalText; headline.classList.remove('cl-counting'); }
        }
        requestAnimationFrame(tick);
      }
    }

    // Chart line draw-on. Tag any rendered .trend-line with .draw-in and
    // set --len from getTotalLength for an accurate dasharray.
    function animateLines(scope) {
      (scope || document).querySelectorAll('polyline.trend-line, path.trend-line').forEach(line => {
        if (line.classList.contains('draw-in')) return;
        try {
          const len = line.getTotalLength ? line.getTotalLength() : 1000;
          line.style.setProperty('--len', Math.ceil(len));
          line.classList.add('draw-in');
        } catch {}
      });
    }
    // Run once after initial render, then on every view activation.
    requestAnimationFrame(() => animateLines(document));
    document.querySelectorAll('.nav-item').forEach(a => {
      a.addEventListener('click', () => {
        // Strip the class so re-entry replays the animation.
        document.querySelectorAll('.trend-line.draw-in').forEach(l => {
          l.classList.remove('draw-in');
          l.style.removeProperty('--len');
        });
        requestAnimationFrame(() => requestAnimationFrame(() => animateLines(document)));
      });
    });
  })();

  // ── chart interactivity (hover crosshair + tooltip) ────────────────────
  // Each chart-host carries its data + viewBox padding as data-* attrs.
  // We bind one mousemove listener per host, find the closest x-bucket,
  // and reposition the in-SVG crosshair + an HTML tooltip anchored to
  // the host. Pure DOM, no chart lib.
  (function chartInteractivity() {
    document.querySelectorAll('.chart-host').forEach(host => {
      let pts;
      try { pts = JSON.parse(host.dataset.chartPoints); }
      catch { return; }
      if (!pts || pts.length < 2) return;

      const svg     = host.querySelector('svg');
      const cross   = host.querySelector('.crosshair');
      const cline   = cross && cross.querySelector('.crosshair-line');
      const cdot    = cross && cross.querySelector('.crosshair-dot');
      const tip     = host.querySelector('.chart-tooltip');
      if (!svg || !cross || !tip) return;

      const padL  = parseFloat(host.dataset.padL);
      const padR  = parseFloat(host.dataset.padR);
      const padT  = parseFloat(host.dataset.padT);
      const padB  = parseFloat(host.dataset.padB);
      const vbW   = parseFloat(host.dataset.vbW);
      const vbH   = parseFloat(host.dataset.vbH);
      const innerW = vbW - padL - padR;
      const innerH = vbH - padT - padB;
      const n = pts.length;
      const xAt = i => padL + (i / (n - 1)) * innerW;
      const type = host.dataset.chartType;

      // Pre-compute Y for each point (cost: scale by max; hitratio: 0..1).
      let yAt;
      if (type === 'cost') {
        let max = 0;
        for (const p of pts) { if ((p.cost || 0) > max) max = p.cost; }
        if (max <= 0) max = 1;
        yAt = i => padT + innerH - ((pts[i].cost || 0) / max) * innerH;
      } else {
        yAt = i => padT + innerH - (pts[i].ratio || 0) * innerH;
      }

      function fmtCostLocal(v) {
        if (v >= 1000) return '$' + Math.round(v).toLocaleString();
        return '$' + v.toFixed(2);
      }
      function anomalyLine(a) {
        if (!a) return '';
        if (a.kind === 'cost_spike') {
          return `<div class="ct-anomaly">▲ spike: ${a.ratio.toFixed(1)}× rolling 7-bucket median</div>`;
        }
        if (a.kind === 'hitratio_drop') {
          return `<div class="ct-anomaly">▼ hit-ratio drop: −${(a.ratio * 100).toFixed(0)} pp vs rolling median</div>`;
        }
        return '';
      }
      function tooltipHTML(i) {
        const p = pts[i];
        if (type === 'cost') {
          return `<div class="ct-label">${escHtml(p.label)}</div>
                  <div class="ct-primary">${fmtCostLocal(p.cost)}</div>
                  <div class="ct-meta">${Number(p.turns).toLocaleString()} turns</div>
                  ${anomalyLine(p.anomaly)}`;
        }
        return `<div class="ct-label">${escHtml(p.label)}</div>
                <div class="ct-primary">${(p.ratio * 100).toFixed(1)}% hit</div>
                ${anomalyLine(p.anomaly)}`;
      }

      function show() { cross.style.opacity = '1'; tip.style.opacity = '1'; }
      function hide() { cross.style.opacity = '0'; tip.style.opacity = '0'; }
      hide();

      svg.addEventListener('mousemove', (e) => {
        // Convert the cursor's screen position into the SVG's viewBox
        // coordinate space. getScreenCTM gives the inverse mapping for free.
        const ctm = svg.getScreenCTM();
        if (!ctm) return;
        const inv = ctm.inverse();
        const ept = svg.createSVGPoint();
        ept.x = e.clientX; ept.y = e.clientY;
        const sp = ept.matrixTransform(inv);
        // Convert SVG x to nearest data index.
        const t = (sp.x - padL) / innerW;
        let i = Math.round(t * (n - 1));
        if (i < 0) i = 0;
        if (i > n - 1) i = n - 1;
        // Crosshair position in SVG coords.
        const cx = xAt(i);
        const cy = yAt(i);
        cline.setAttribute('x1', cx);
        cline.setAttribute('x2', cx);
        cdot.setAttribute('cx', cx);
        cdot.setAttribute('cy', cy);
        // Tooltip in DOM coords — map the SVG point back to screen, then
        // subtract host's offset to get host-relative pixels.
        const sptOut = svg.createSVGPoint();
        sptOut.x = cx; sptOut.y = cy;
        const dom = sptOut.matrixTransform(ctm);
        const hostRect = host.getBoundingClientRect();
        tip.style.left = `${dom.x - hostRect.left}px`;
        tip.style.top  = `${dom.y - hostRect.top}px`;
        tip.innerHTML  = tooltipHTML(i);
        show();
      });
      svg.addEventListener('mouseleave', hide);
    });
  })();
})();
</script>
{{if .ServeMode}}
<style>
  /* Reload toast — fallback when a silent reload has been deferred
     for a long time (e.g. user has details open for minutes while new
     data has piled up). The default reload path is silent; the toast
     only appears as the "too stale to ignore" signal. */
  .claudit-reload-toast {
    position: fixed; right: 16px; bottom: 16px; z-index: 9999;
    display: none; align-items: center; gap: 10px;
    padding: 10px 14px; border-radius: var(--r-md);
    background: var(--surface); color: var(--ink);
    border: 1px solid var(--border-strong);
    box-shadow: var(--shadow-md);
    font: 500 var(--t-3)/1.3 var(--font-sans);
  }
  .claudit-reload-toast.is-visible { display: inline-flex; }
  .claudit-reload-toast button {
    border: 1px solid var(--border-strong); background: var(--accent);
    color: white; padding: 6px 10px; border-radius: var(--r-sm);
    font: 600 var(--t-2)/1 var(--font-sans); cursor: pointer;
  }
  .claudit-reload-toast .dismiss {
    background: transparent; color: var(--muted); border-color: transparent;
  }
  /* Date-range popover — appended to <body> at runtime by the picker
     JS, positioned beneath the brand-sub button. */
  .claudit-date-popover {
    position: absolute; z-index: 9997;
    display: none;
    background: var(--surface); color: var(--ink);
    border: 1px solid var(--border-strong); border-radius: var(--r-md);
    box-shadow: var(--shadow-md);
    padding: var(--s-3); min-width: 240px;
    font: 500 var(--t-3)/1.3 var(--font-sans);
  }
  .claudit-date-popover.is-visible { display: block; }
  .claudit-date-popover .row {
    display: flex; flex-direction: column; gap: 2px;
    margin-bottom: var(--s-2);
  }
  .claudit-date-popover label {
    font-size: var(--t-2); color: var(--muted); font-weight: 600;
  }
  .claudit-date-popover input[type="date"] {
    font: inherit; padding: var(--s-1) var(--s-2);
    border: 1px solid var(--border); border-radius: 4px;
    background: var(--surface); color: var(--ink);
    color-scheme: light dark;
  }
  .claudit-date-popover input[type="date"]:focus-visible {
    outline: 2px solid var(--accent); outline-offset: 1px;
    border-color: var(--accent);
  }
  .claudit-date-popover .buttons {
    display: flex; gap: var(--s-2); justify-content: flex-end;
    margin-top: var(--s-2);
  }
  .claudit-date-popover button {
    border: 1px solid var(--border-strong); background: var(--surface);
    color: var(--ink); padding: 6px 10px; border-radius: var(--r-sm);
    font: 600 var(--t-2)/1 var(--font-sans); cursor: pointer;
  }
  .claudit-date-popover button.primary {
    background: var(--accent); color: white; border-color: var(--accent);
  }
  .claudit-date-popover button.subtle {
    background: transparent; border-color: transparent; color: var(--muted);
  }
  @media print {
    .claudit-reload-toast, .claudit-date-popover { display: none !important; }
  }
</style>
<div id="claudit-reload-toast" class="claudit-reload-toast" role="status" aria-live="polite">
  <span>Updated data is ready.</span>
  <button type="button" data-action="reload">Reload now</button>
  <button type="button" data-action="dismiss" class="dismiss" aria-label="Dismiss">×</button>
</div>
<script>
(function () {
  // Auto-reload for `claudit serve`. ServeMode=true gates this whole
  // block, so one-shot HTML renders are unaffected.
  //
  // Strategy: every RELOAD_INTERVAL_MS, attempt a silent reload.
  // Defer when the user is plausibly mid-read — a yanked-page is
  // worse than slightly-stale data. Deferral checks:
  //   - page is hidden (tab not focused) → wait for visibility
  //   - any <details> is open → user expanded something specific
  //   - mouse/keyboard/scroll activity within ACTIVITY_GRACE_MS
  // If a reload has been deferred for OVERDUE_MS while new data has
  // piled up, surface the toast so the user can opt in.
  var STATUS_URL          = "{{.StatusPath}}";
  var INITIAL_GEN         = {{.Generation}};
  var RELOAD_INTERVAL_MS  = {{.ReloadIntervalSec}} * 1000;
  var STATUS_POLL_MS      = 5000;
  var ACTIVITY_GRACE_MS   = 10000;
  var OVERDUE_MS          = 5 * 60 * 1000;

  var lastActivity = Date.now();
  var firstDeferralAt = 0;
  var dismissed = false;
  var currentGen = INITIAL_GEN;

  function markActivity() { lastActivity = Date.now(); }
  ['scroll', 'mousemove', 'mousedown', 'keydown', 'wheel', 'touchstart']
    .forEach(function (ev) {
      window.addEventListener(ev, markActivity, { passive: true, capture: true });
    });

  var toast = document.getElementById('claudit-reload-toast');
  if (toast) {
    toast.querySelector('[data-action="reload"]').addEventListener('click', function () {
      window.location.reload();
    });
    toast.querySelector('[data-action="dismiss"]').addEventListener('click', function () {
      toast.classList.remove('is-visible');
      dismissed = true;
    });
  }
  function showToast() {
    if (!toast || dismissed) return;
    toast.classList.add('is-visible');
  }

  function canReload() {
    if (document.hidden) return false;
    if (Date.now() - lastActivity < ACTIVITY_GRACE_MS) return false;
    if (document.querySelector('details[open]')) return false;
    return true;
  }

  function attemptReload() {
    if (currentGen <= INITIAL_GEN) {
      // No new data — nothing to do; reset the overdue timer.
      firstDeferralAt = 0;
      return;
    }
    if (canReload()) {
      window.location.reload();
      return;
    }
    if (firstDeferralAt === 0) firstDeferralAt = Date.now();
    if (Date.now() - firstDeferralAt >= OVERDUE_MS) {
      showToast();
    }
  }

  // Cadence 1: try a silent reload on a steady interval.
  setInterval(attemptReload, RELOAD_INTERVAL_MS);
  // Cadence 2: poll /status so currentGen tracks server-side data.
  // Independent of the reload tick so we can react to a generation
  // change at the next interval rather than the next poll.
  function pollStatus() {
    fetch(STATUS_URL, { headers: { 'Accept': 'application/json' } })
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (s) {
        if (s && typeof s.generation === 'number') currentGen = s.generation;
        setTimeout(pollStatus, STATUS_POLL_MS);
      })
      .catch(function () { setTimeout(pollStatus, STATUS_POLL_MS * 6); });
  }
  pollStatus();

  // Reload immediately when the tab regains focus IF new data is
  // already pending — the user wasn't watching anyway.
  document.addEventListener('visibilitychange', function () {
    if (!document.hidden && currentGen > INITIAL_GEN && canReload()) {
      window.location.reload();
    }
  });

  // ── date-range picker ────────────────────────────────────────────
  // Clicking the brand-sub button opens a small popover with two
  // native <input type="date"> fields and Apply/Clear/Cancel. Apply
  // navigates to a URL with since/until set + scope=all so server
  // defaults don't snap back over the user's explicit choice. Clear
  // strips the date filter. Cancel just closes.
  (function () {
    var btn = document.getElementById('date-range-button');
    if (!btn) return;
    var popover = null;
    function ymd(d) {
      var y = d.getFullYear();
      var m = String(d.getMonth() + 1).padStart(2, '0');
      var dd = String(d.getDate()).padStart(2, '0');
      return y + '-' + m + '-' + dd;
    }
    // Add/subtract one calendar day to a YYYY-MM-DD string. UTC math
    // dodges local-timezone DST surprises — claudit treats date-only
    // values as UTC midnight throughout (see time.Parse callsites).
    //
    // The picker presents End as INCLUSIVE to the user; internally
    // the server's `until` field is exclusive (matches --until on the
    // report CLI). We translate at the picker boundary: +1 day on
    // Apply, -1 day when seeding the input from a URL.
    function addDays(ymdStr, delta) {
      var parts = ymdStr.split('-').map(Number);
      var dt = new Date(Date.UTC(parts[0], parts[1] - 1, parts[2]));
      dt.setUTCDate(dt.getUTCDate() + delta);
      var Y = dt.getUTCFullYear();
      var M = String(dt.getUTCMonth() + 1).padStart(2, '0');
      var D = String(dt.getUTCDate()).padStart(2, '0');
      return Y + '-' + M + '-' + D;
    }
    function build() {
      if (popover) return popover;
      popover = document.createElement('div');
      popover.className = 'claudit-date-popover';
      popover.setAttribute('role', 'dialog');
      popover.setAttribute('aria-label', 'Select date range');
      popover.innerHTML =
        '<div class="row"><label for="claudit-date-start">Start</label>' +
        '<input id="claudit-date-start" type="date"></div>' +
        '<div class="row"><label for="claudit-date-end">End</label>' +
        '<input id="claudit-date-end" type="date"></div>' +
        '<div class="buttons">' +
        '<button type="button" class="subtle" data-action="clear">Clear</button>' +
        '<button type="button" data-action="cancel">Cancel</button>' +
        '<button type="button" class="primary" data-action="apply">Apply</button>' +
        '</div>';
      document.body.appendChild(popover);
      popover.querySelector('[data-action="apply"]').addEventListener('click', apply);
      popover.querySelector('[data-action="clear"]').addEventListener('click', clear);
      popover.querySelector('[data-action="cancel"]').addEventListener('click', close);
      // Don't let clicks inside the popover bubble up to the doc-click
      // handler, which would close it.
      popover.addEventListener('click', function (e) { e.stopPropagation(); });
      popover.querySelector('#claudit-date-start')
        .addEventListener('keydown', onPopoverKey);
      popover.querySelector('#claudit-date-end')
        .addEventListener('keydown', onPopoverKey);
      return popover;
    }
    function onPopoverKey(e) {
      if (e.key === 'Enter') { e.preventDefault(); apply(); }
    }
    function position() {
      if (!popover) return;
      var rect = btn.getBoundingClientRect();
      popover.style.top = (rect.bottom + window.scrollY + 6) + 'px';
      popover.style.left = (rect.left + window.scrollX) + 'px';
    }
    function seedInputs() {
      var p = new URLSearchParams(window.location.search);
      var start = p.get('since');
      var endExcl = p.get('until');
      // Translate the URL's exclusive `until` into the user-facing
      // inclusive End: subtract one day for display so the picker
      // shows what they actually selected last time.
      var end = endExcl ? addDays(endExcl, -1) : '';
      if (!start && !end) {
        // Default seed mirrors the server's last=7d default scope so
        // the picker opens onto values that match what the user is
        // currently seeing.
        var now = new Date();
        var weekAgo = new Date(now);
        weekAgo.setDate(now.getDate() - 7);
        start = ymd(weekAgo);
        end = ymd(now);
      }
      popover.querySelector('#claudit-date-start').value = start || '';
      popover.querySelector('#claudit-date-end').value = end || '';
    }
    function open() {
      build();
      seedInputs();
      position();
      popover.classList.add('is-visible');
      btn.setAttribute('aria-expanded', 'true');
      // Delay the doc-click binding by a tick so the click that
      // opened us doesn't immediately close us.
      setTimeout(function () {
        document.addEventListener('click', onDocClick);
        document.addEventListener('keydown', onDocKey);
        window.addEventListener('resize', position);
        window.addEventListener('scroll', position, true);
      }, 0);
      popover.querySelector('#claudit-date-start').focus();
    }
    function close() {
      if (popover) popover.classList.remove('is-visible');
      btn.setAttribute('aria-expanded', 'false');
      document.removeEventListener('click', onDocClick);
      document.removeEventListener('keydown', onDocKey);
      window.removeEventListener('resize', position);
      window.removeEventListener('scroll', position, true);
    }
    function onDocClick(e) {
      if (popover && !popover.contains(e.target) && e.target !== btn) close();
    }
    function onDocKey(e) {
      if (e.key === 'Escape') { close(); btn.focus(); }
    }
    function apply() {
      var s = popover.querySelector('#claudit-date-start').value;
      var en = popover.querySelector('#claudit-date-end').value;
      if (s && en && s > en) {
        alert('Start date must be on or before end date.');
        return;
      }
      var p = new URLSearchParams(window.location.search);
      if (s) p.set('since', s); else p.delete('since');
      // Translate the user-facing inclusive End to the server's
      // exclusive `until` by adding one day. "End = 2026-05-15"
      // means "include everything on 2026-05-15", i.e. `until` =
      // 2026-05-16.
      if (en) p.set('until', addDays(en, 1)); else p.delete('until');
      p.delete('last');       // since/until override last
      p.set('scope', 'all');  // explicit user choice — disable server defaults
      var qs = p.toString();
      window.location.search = qs ? ('?' + qs) : '';
    }
    function clear() {
      var p = new URLSearchParams(window.location.search);
      p.delete('since');
      p.delete('until');
      p.delete('last');
      p.set('scope', 'all');
      var qs = p.toString();
      window.location.search = qs ? ('?' + qs) : '';
    }
    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      if (popover && popover.classList.contains('is-visible')) close();
      else open();
    });
  })();
})();
</script>
